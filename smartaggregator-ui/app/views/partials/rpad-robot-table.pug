.container.data-groups.active    
    .row 
        .col-sm-12
            div.table-div
                table#robot-table
                    thead 
                        tr 
                            th.col-1(style="background-color:#F5F5F5; width:80%;")  #{__('Release Name')}
                            th.col-2(style="background-color:#F5F5F5; width:20%;")  #{__('Last Data Date')}
                    tbody
                        each item in robots
                            tr 
                                td.text-center(style="background-color: white; width:80%;")=item.releaseName != null ? item.releaseName : 'N/A'
                                td.text-center(style="background-color: white; width:20%;")
                                    if locale == 'en'
                                        i.fas.fa-circle.font-20.circleReportIcon.robot-color.tooltip2(class = (item.lastDataDate <= 15 ? 'text-success' : (item.lastDataDate > 15 && item.lastDataDate < 30 ? 'text-warning' : 'text-danger')) style='color: whitesmoke' data-toggle='tooltip' data-placement='left' title='' data-original-title="Last data uploaded to this robot " + item.lastDataDate + " day ago.")
                                    if locale == 'tr'
                                        i.fas.fa-circle.font-20.circleReportIcon.robot-color.tooltip2(class = (item.lastDataDate <= 15 ? 'text-success' : (item.lastDataDate > 15 && item.lastDataDate < 30 ? 'text-warning' : 'text-danger')) style='color: whitesmoke' data-toggle='tooltip' data-placement='left' title='' data-original-title="Son veri yüklenme zamanı " + item.lastDataDate + " gün önce.")