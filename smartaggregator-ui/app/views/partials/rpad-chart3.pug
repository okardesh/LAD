div.active.pie-3d-stack
    div#rpad-chart3-depth.pie-3d-stack__depth
    div#rpad-chart3.pie-3d-stack__top

script.
    // DEFAULT GELEN WORKING HOURS OCCUPANCY RATE CHART VERILERI
    function toIntValue(value){
        const parsed = parseInt(value, 10);
        return Number.isFinite(parsed) ? parsed : 0;
    }

    var todayOccupancyControl = new Date();
    var startTimeYearOccupancyControl = todayOccupancyControl.getFullYear();
    var startTimeMonthOccupancyControl = todayOccupancyControl.getMonth()+1;
    var startTimeDayOccupancyControl = todayOccupancyControl.getDate();

    var lastStartTimeOccupancyControl = ('0' + startTimeDayOccupancyControl).slice(-2) + '/' + ('0' + startTimeMonthOccupancyControl).slice(-2) + '/' + startTimeYearOccupancyControl;
    let workedDateValue = lastStartTimeOccupancyControl;
    const workingHoursOccupancyChart = JSON.parse('!{JSON.stringify(workingHoursOccupancyChart)}');

    const chartWHOR = [];
    let totalOccupancy = 0;
    let workedHoursValue = 0;
    let freeHoursValue = 0;
    workingHoursOccupancyChart.forEach(function(element) {
        Object.keys(element).forEach(function(key) {
            if(key === 'freeHours' || key === 'workedHours'){
                totalOccupancy = totalOccupancy + toIntValue(element[key]);
            }
            if(key === 'freeHours'){
                freeHoursValue = toIntValue(element[key])
            } else if(key === 'workDate'){
                if(element[key] === null){
                    workedDateValue = new Date();
                }
                else{
                    workedDateValue = element[key];
                }
            } else if(key === 'workedHours'){
                workedHoursValue = toIntValue(element[key])
            }
        });
    });
    // workingHoursOccupancyChart.forEach(function(element){
    //     Object.keys(element).forEach(function(key){
    //         if (key === 'workedHours'){
    //              totalOccupancy = totalOccupancy + parseInt(element[key])
    //         }
    //         else if (key === 'workedHours'){
    //             workedHoursValue = parseInt
    //         }
    //     })
    // })
    let totalAvailableMinutes = toIntValue(workedHoursValue) + toIntValue(freeHoursValue);
    let totalWorkedPercent = totalAvailableMinutes > 0 ? Math.round((toIntValue(workedHoursValue) / totalAvailableMinutes) * 100) : 0;
    let totalFreePercent = totalAvailableMinutes > 0 ? Math.round((toIntValue(freeHoursValue) / totalAvailableMinutes) * 100) : 0;
    totalOccupancy = 0;
    chartWHOR.push({
        type : `#{__('Worked Minutes')} : %${totalWorkedPercent} - ${workedHoursValue} #{__('Minutes')}`,
        value : workedHoursValue,
    });

    chartWHOR.push({
        type : `#{__('Free Minutes')} : %${totalFreePercent} - ${freeHoursValue} #{__('Minutes')}`,
        value : freeHoursValue,
    });
    const whPieColors = ['#62DAAB', '#FF4D4F'];
    const whPieIs3D = window.__rpad3dEnabled !== false;
    const whPieRadius = 0.88;
    const whPieInnerRadius = 0.62;

    function renderWorkingHoursMetricCard(rows) {
        const worked = rows && rows[0] ? (parseInt(rows[0].value, 10) || 0) : 0;
        const free = rows && rows[1] ? (parseInt(rows[1].value, 10) || 0) : 0;
        const total = worked + free;
        const workedPct = total > 0 ? Math.round((worked / total) * 100) : 0;
        const freePct = total > 0 ? Math.round((free / total) * 100) : 0;

        $('#rpad-chart3').html(`
            <div class="metric-3d-card" style="--metric-primary:#f59e0b; --metric-primary-light:#f9c15d; --metric-percent:${workedPct}; --metric-percent-str:${workedPct}%">
                <div class="metric-3d-card__top">
                    <div>
                        <div class="metric-3d-card__headline">#{__('Worked Minutes')}</div>
                        <div class="metric-3d-card__percent">${workedPct}%</div>
                        <div class="metric-3d-card__sub">${total} #{__('Minutes')} · ${workedDateValue}</div>
                    </div>
                    <div class="metric-3d-card__ring"></div>
                </div>
                <div class="metric-3d-card__bar-wrap">
                    <div class="metric-3d-card__bar-track">
                        <div class="metric-3d-card__bar-fill"></div>
                    </div>
                </div>
                <div class="metric-3d-card__legend">
                    <div class="metric-3d-card__legend-row">
                        <span class="metric-3d-card__legend-dot" style="background:#f59e0b"></span>
                        <span>#{__('Worked Minutes')}</span>
                        <span class="metric-3d-card__legend-value">${worked} #{__('Minutes')}</span>
                    </div>
                    <div class="metric-3d-card__legend-row">
                        <span class="metric-3d-card__legend-dot" style="background:#ff4d4f"></span>
                        <span>#{__('Free Minutes')}</span>
                        <span class="metric-3d-card__legend-value">${freePct}% · ${free} #{__('Minutes')}</span>
                    </div>
                </div>
            </div>
        `);
    }
    
    const piePlot3 = whPieIs3D ? null : new Pie('rpad-chart3', {
        appendPadding: [8, 18, 0, 18],
        data : chartWHOR,
        angleField: 'value',
        colorField: 'type',
        radius: whPieRadius,
        height: 270,
        innerRadius: whPieInnerRadius,
        label: {
            type: 'inner',
            offset: '-45%',
            content: '',
            style: {
                textAlign: 'center',
                fontSize: 11,
                fill: '#111827',
                fontWeight: 600
                },
        },
        legend: {
            layout: 'vertical',
            position: 'bottom',
            itemName: {
                style: {
                    fontSize: 12,
                    fill: '#475467'
                }
            }
        },
        color: whPieColors,
        tooltip: {
            customContent: (title, data) => {
                let insideItem;
                if(data[0] != null || data[0] != undefined){
                    insideItem = data[0].data;
                    if(insideItem != null || insideItem != undefined){
                        return `<div class="tooltip-div">
                                    <h5 class="tooltip-header d-inline">${insideItem.type}</h5>
                                </div>`;
                        }
                    }
                }
            },
        interactions: [{ type: 'element-selected' }, { type: 'element-active' }],
        statistic: {
            title: false,
            content: {
            style: {
                whiteSpace: 'pre-wrap',
                overflow: 'hidden',
                textOverflow: 'ellipsis',
            },
            content: '',
            },
        },
    });

    if (whPieIs3D) {
        renderWorkingHoursMetricCard(chartWHOR);
    } else {
        piePlot3.render();
    }

    function requestOccupancySummaryForDate(selectedDate, robots){
        return new Promise(function(resolve){
            $.ajax({
                url: "/robotsOccupancyRateChart-filter",
                type: 'POST',
                data: { startTime: selectedDate, endTime: selectedDate },
                dataType: 'json',
                success: function(res){
                    if (res && res.rpadJobsList && res.rpadJobsList.length > 0) {
                        let worked = 0, free = 0;
                        res.rpadJobsList.forEach(function(row){
                            worked += toIntValue(row.fullTime);
                            free += toIntValue(row.freeTime);
                        });
                        resolve({ worked: worked, free: free });
                        return;
                    }

                    resolve({ worked: 0, free: 0 });
                },
                error: function(){
                    resolve({ worked: 0, free: 0 });
                }
            });
        });
    }

    $( window ).on( "load", function() {
        options = {
            format: "dd/mm/yyyy",
            orientation: 'bottom left',
            language: locale,
            autoclose: true,
        };
        $('input[name="workDate"]').datepicker(options);
        // EN SON CALISILAN GUNUN DEFAULT OLARAK CHARTA YANSITILMASINI SAGLAYAN KISIM
        //- $('input[name="workDate"]').datepicker("setDate", workedDateValue);
        //- $('input[name="workDate"]').attr('value', workedDateValue);
        //-     dailyDensityChartFilterFunction3();
        //- });
        let workingHoursOccupancyRobots = filters.rpadHistoryList[2]?.robots?.split(', ') || undefined
        let workingHoursOccupancyStartTime = filters.rpadHistoryList[2]?.date1 || undefined
        if (workingHoursOccupancyRobots !== undefined ){
            $('select[name="whoRobots"]').val(workingHoursOccupancyRobots);
        }
        $('input[name="workDate"]').datepicker("setDate", dashboardDataWeekRange.end);
        dailyDensityChartFilterFunction3();
    });

        // DATEPICKERDA OLAN HER DEGISIKLIKTE dailyDensityChartFilterFunction3 FONKSIYONUNUN TETIKLENDIGI KISIM
        $('input[name="workDate"]').on('change', function () {
            dailyDensityChartFilterFunction3()
        });
        $('select[name="whoRobots"]').on('change', function () {
            dailyDensityChartFilterFunction3();
        });

        // HER FILTRELEME ISLEMINDE GONDERILEN SORGU ISLEMINE AIT FONKSIYON
        function dailyDensityChartFilterFunction3() {
            const selectedDate = $(workDate).val();
            let occupanyRobots = ensureSelectHasValue('whoRobots');
            let workingHoursOcpChartAlert = '';

            if (occupanyRobots.length < 1) {
                workingHoursOcpChartAlert = workingHoursOcpChartAlert + ' * ' + "#{__('Robots are empty')}"
            }
            $('#alertWorkingHourChart').empty()
            $("<p class='alertText' style='color:red!important;'>" + workingHoursOcpChartAlert + "</p>").appendTo('#alertWorkingHourChart')
            if (workingHoursOcpChartAlert === '') {
                filterworkingHoursOccupancyChart = {workDate: selectedDate, robots: occupanyRobots};
                filterworkingHoursOccupancyChart.workDate = workDate.value;
                $.ajax({
                    url: "/workingHoursOccupancyChart-filter",
                    type: 'POST',
                    data: filterworkingHoursOccupancyChart,
                    dataType: 'json', // added data type
                    success: function (res) {
                        let WHOC1 = [];
                        if (res && res.rpadDailyIntensityList && res.rpadDailyIntensityList.length > 0) {
                            $('#rpad-chart3').removeClass('visibility-none')
                            res.rpadDailyIntensityList.forEach(function (element) {
                                Object.keys(element).forEach(function (key) {
                                    if (key === 'freeHours' || key === 'workedHours') {
                                        totalOccupancy = totalOccupancy + toIntValue(element[key]);
                                    }
                                    if (key === 'freeHours') {
                                        freeHoursValue = toIntValue(element[key])
                                    } else if (key === 'workDate') {
                                        workedDateValue = element[key]
                                    } else if (key === 'workedHours') {
                                        workedHoursValue = toIntValue(element[key])
                                    }
                                });
                            });
                            let freeMinutes = toIntValue(freeHoursValue);
                            let workedMinutes = toIntValue(workedHoursValue);

                            requestOccupancySummaryForDate(selectedDate, occupanyRobots).then(function(occ){
                                if (freeMinutes === 0 && occ.free > 0) {
                                    freeMinutes = toIntValue(occ.free);
                                }
                                if (workedMinutes === 0 && occ.worked > 0) {
                                    workedMinutes = toIntValue(occ.worked);
                                }

                                let totalAvailableHours = freeMinutes + workedMinutes;
                                let totalFreePercent = totalAvailableHours > 0 ? Math.round((freeMinutes / totalAvailableHours) * 100) : 0;
                                let totalWorkedPercent = totalAvailableHours > 0 ? Math.round((workedMinutes / totalAvailableHours) * 100) : 0;
                                totalOccupancy = 0;
                                WHOC1.push({
                                    type: `#{__('Worked Minutes')} : %${totalWorkedPercent} - ${workedMinutes} #{__('Minutes')}`,
                                    value: workedMinutes,
                                });

                                WHOC1.push({
                                    type: `#{__('Free Minutes')} : %${totalFreePercent} - ${freeMinutes} #{__('Minutes')}`,
                                    value: freeMinutes,
                                });
                                if (whPieIs3D) {
                                    renderWorkingHoursMetricCard(WHOC1);
                                } else {
                                    piePlot3.changeData(WHOC1);
                                    piePlot3.render();
                                }
                            });
                        } else {
                            $('#rpad-chart3').addClass('visibility-none')
                        }

                    },
                    error: function (err) {
                        $('#rpad-chart3').addClass('visibility-none')
                    }
                });
            }
        }
 