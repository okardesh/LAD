div.active#rpad-chart7

script.
    const { Bar } = G2Plot;
    const releaseTotalTimeChart = JSON.parse('!{JSON.stringify(releaseTotalTimeChart)}');
    const releaseTotalTimeDataDate = JSON.parse('!{JSON.stringify(jobsData)}');
    const chartRTTC = [];
    let order = 1;
    releaseTotalTimeChart.sort((a, b) => b.totalJobTime - a.totalJobTime).forEach(element => {
        chartRTTC.push({
            releaseName : element.releaseName.slice(0,20) + " - " + order,
            totalJobTime: element.totalJobTime,
            releaseNameLong : element.releaseName
        })
        order++;
    });
    const fallbackNow = new Date();
    const fallbackMonth = (`0${fallbackNow.getMonth() + 1}`).slice(-2);
    const fallbackYear = `${fallbackNow.getFullYear()}`;
    const lastUploadParts = (lastJobsDate || '').split('/');
    let newMonthLastData = lastUploadParts.length === 3 ? lastUploadParts[1] : fallbackMonth;
    let newYearLastData = lastUploadParts.length === 3 ? lastUploadParts[2] : fallbackYear;

    $('select[id="releaseTotalTimeChart_year"]').val(newYearLastData);
    const barPlot2 = new Bar('rpad-chart7', {
        forceFit: true,
        data : chartRTTC,
        appendPadding : [20, 20, 20, 20],
        height: 515,
        xField: 'totalJobTime',
        yField: 'releaseName',
        color: (window.__rpad3dEnabled !== false) ? () => 'l(0) 0:#68c3ff 0.5:#4a90f0 1:#2f5ecc' : '#4e86e8',
        barStyle: (window.__rpad3dEnabled !== false) ? {
            radius: [0, 8, 8, 0],
            shadowColor: 'rgba(15, 23, 42, 0.24)',
            shadowBlur: 10,
            shadowOffsetY: 6,
        } : { radius: [0, 2, 2, 0] },
        scrollbar: {
            type: 'vertical',
            animate: false,
        },
        meta: {
            type: {
            alias: 'Total Time',
            },
        },
        tooltip: {
            customContent: (title, data) => {
                let insideItem;
                if(data[0] != null || data[0] != undefined){
                    insideItem = data[0].data;
                    if(insideItem != null || insideItem != undefined){
                        return `<div class="tooltip-div">
                                    <h5 class="tooltip-header">${insideItem.releaseNameLong}</h5><h5 class="tooltip-content">#{__('Total Job Time')} : ${insideItem.totalJobTime} #{__('Minutes')}</h5>
                                </div>`;
                    }
                }
            }
        },
        xAxis: {
            grid: {
                line: {
                    style: {
                        stroke: '#e8edf7',
                        lineDash: [4, 4]
                    }
                }
            }
        }
    });

    barPlot2.render();
        let newOptions = {}
        newOptions = {
            "#{__('Select Month')}": '00',"#{__('January')}": '01',"#{__('February')}": '02',"#{__('March')}": '03',
            "#{__('April')}": '04',"#{__('May')}": '05',"#{__('June')}": '06',
            "#{__('July')}": '07',"#{__('August')}": '08',"#{__('September')}": '09',
            "#{__('October')}": '10',"#{__('November')}": '11',"#{__('December')}": '12'
        };
        var $el = $("#releaseTotalTimeChart_month");
        //- $el.empty();
        $.each(newOptions, function(key,value) {
            if(value === newMonthLastData){
                $el.append($("<option></option>").attr("value", value).attr("selected", true).text(key));
                
            } else {
                $el.append($("<option></option>").attr("value", value).text(key));
            }
        });
        
        $( window ).on( "load", function(){
            let separatedRobots6 = filters.rpadHistoryList[5]?.robots?.split(', ') || undefined;
            let startTimeDatePicker = filters.rpadHistoryList[5]?.date1 || undefined ;
            let endTimeDatePicker = filters.rpadHistoryList[5]?.date2 || undefined;
            if ( startTimeDatePicker !== undefined && endTimeDatePicker !== undefined && separatedRobots6 !== undefined){
                $.each(newOptions, function(key,value) {
                if(value === endTimeDatePicker){
                    $el.append($("<option></option>").attr("value", value).attr("selected", true).text(key));
                    
                } else {
                    $el.append($("<option></option>").attr("value", value).text(key));
                }
                });
                $('select[name="releaseRobots"]').val(separatedRobots6);
                $('select[id="releaseTotalTimeChart_year"]').val(startTimeDatePicker);
                $('select[id="releaseTotalTimeChart_month"]').val(endTimeDatePicker);
            }
            else{
                $('select[id="releaseTotalTimeChart_year"]').val(newYearLastData);
                $('select[id="releaseTotalTimeChart_month"]').val(newMonthLastData);
            }            
            ensureSelectHasValue('releaseRobots');
            releaseChartFilterFunction();
        });
        $('select[id="releaseTotalTimeChart_year"]').on('change', function () {
            releaseChartFilterFunction();
        });
        $('select[id="releaseTotalTimeChart_month"]').on('change', function(){
            releaseChartFilterFunction();
        });
        $('select[name="releaseRobots"]').on('change', function(){
            releaseChartFilterFunction();
        });


        function releaseChartFilterFunction(){
            let releaseChartYear = $('select[id="releaseTotalTimeChart_year"]').val();
            let releaseChartMonth = $('select[id="releaseTotalTimeChart_month"]').val();
            let releaseChartRobots = ensureSelectHasValue('releaseRobots');

            let releaseChartAlert = '';
            if(releaseChartYear === '' || releaseChartYear === 'Yıl Seçin'){
                releaseChartAlert = releaseChartAlert + ' * ' + "#{__('Year is empty')}"
            }
            if(releaseChartMonth === '00' || releaseChartMonth === 'Ay Seçin'){
                releaseChartAlert = releaseChartAlert + ' * ' + "#{__('Month is empty')}"
            }
            if(releaseChartRobots.length < 1){
                releaseChartAlert = releaseChartAlert + ' * ' + "#{__('Robots are empty')}"
            }
            $('#alertTextReleaseChart').empty()
            $("<p class='alertText' style='color:red!important;'>" + releaseChartAlert + "</p>").appendTo('#alertTextReleaseChart')
            if(releaseChartAlert === '') {
                filterReleaseTotalTimeChart = {year:'', month:'',robots :''};
                filterReleaseTotalTimeChart.year = $('select[id="releaseTotalTimeChart_year"]').val();
                filterReleaseTotalTimeChart.month = $('select[id="releaseTotalTimeChart_month"]').val();
                filterReleaseTotalTimeChart.robots = $('select[name="releaseRobots"]').val();
                const _monthVal7 = $('select[id="releaseTotalTimeChart_month"]').val();
                filterReleaseTotalTimeChart.month = ($('select[id="releaseTotalTimeChart_year"]').val() && $('select[id="releaseTotalTimeChart_year"]').val() !== '' && _monthVal7) ? _monthVal7.split(',').map(Number) : '';
            }
            if(releaseChartAlert === '' && filterReleaseTotalTimeChart.year != '' && filterReleaseTotalTimeChart.month != '' && filterReleaseTotalTimeChart.robots != '') {
                $.ajax({
                    url: "/releaseTotalTimeChart-filter",
                    type: 'POST',
                    data: filterReleaseTotalTimeChart,
                    dataType: 'json', // added data type
                    success: function(res) {
                        let TTWM = [];
                        if(res && res.rpadJobsList && res.rpadJobsList.length > 0) {
                            $('#rpad-chart7').removeClass('visibility-none')
                            let order = 1;
                            res.rpadJobsList.sort((a, b) => b.totalJobTime - a.totalJobTime).forEach(element => {
                                TTWM.push({
                                    releaseName : element.releaseName.slice(0,20) + " - " + order,
                                    totalJobTime: element.totalJobTime,
                                    releaseNameLong : element.releaseName
                                })
                                order++;
                            });
                            barPlot2.changeData(TTWM);
                            barPlot2.render();
                        }else{
                            $('#rpad-chart7').addClass('visibility-none')
                        }
                    },
                    error: function(err){
                    }
                });
            }
        }