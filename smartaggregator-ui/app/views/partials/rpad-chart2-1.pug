        $('input[name="startTimeRobotsOccupancyRateDatePicker"]').on('change', function () {
            if (responseControl2 === 0) {
                stateChartFilterFunction2();
            }else{
                responseControl2 = 0;
            }
        });
        $('input[name="endTimeRobotsOccupancyRateDatePicker"]').on('change', function(){
            if(responseControl2 === 0){
                stateChartFilterFunction2();
            }else{
                responseControl2 = 0;
            }
        });
        $('select[name="occupanyRobots"]').on('change', function(){
            stateChartFilterFunction2();
        });


    // DATEPICKER ILE GINDERILEN TARIH ARALIKLARININ SORGUYA GONDERILMEDEN ONCE DUZENLENIGI KISIM
    // robotsOccupancFilterRequest FONKSIYONUNA PARAMETRE OLARAK GONDERILIR
    function stateChartFilterFunction2(){
        let selectedDateStartDate3 = $('input[name="startTimeRobotsOccupancyRateDatePicker"]').val();
        let selectedDateEndDate3 = $('input[name="endTimeRobotsOccupancyRateDatePicker"]').val();
        let occupanyRobots = ensureSelectHasValue('occupanyRobots');
        let robotOcpChartAlert = '';

        let startDateDataDay = selectedDateStartDate3.slice(0, 2);
        let startDateDataMonth = selectedDateStartDate3.slice(3, 5);
        let startDateDataYear = selectedDateStartDate3.slice(6, 10);
        startDateDataDate = new Date(startDateDataYear + '-' + startDateDataMonth + '-' + startDateDataDay);

        let endDateDataDay = selectedDateEndDate3.slice(0, 2);
        let endDateDataMonth = selectedDateEndDate3.slice(3, 5);
        let endDateDataYear = selectedDateEndDate3.slice(6, 10);
        endDateDataDate = new Date(endDateDataYear + '-' + endDateDataMonth + '-' + endDateDataDay);

        if(selectedDateStartDate3 === 'Start Date' || selectedDateStartDate3 === 'Başlangıç Tarihi' || selectedDateStartDate3 === 'Tarih Seçiniz'){
            robotOcpChartAlert = robotOcpChartAlert + ' * ' + "#{__('Start date is empty')}"
        }
        if (endDateDataDate < startDateDataDate && !(selectedDateStartDate3 === 'Start Date' || selectedDateStartDate3 === 'Başlangıç Tarihi' || selectedDateStartDate3 === 'Tarih Seçiniz') && !(selectedDateEndDate3 === 'End Date' || selectedDateEndDate3 === 'Bitiş Tarihi' || selectedDateEndDate3 === 'Tarih Seçiniz')) {
            robotOcpChartAlert = robotOcpChartAlert + ' * ' + "#{__('The start date must be less than the end date.')}"
        }
        if(selectedDateEndDate3 === 'End Date' || selectedDateEndDate3 === 'Bitiş Tarihi' || selectedDateEndDate3 === 'Tarih Seçiniz'){
            robotOcpChartAlert = robotOcpChartAlert + ' * ' + "#{__('End date is empty')}"
        }
        if(occupanyRobots.length < 1){
            robotOcpChartAlert = robotOcpChartAlert + ' * ' + "#{__('Robots are empty')}"
        }
        $('#alertrobotOcpChart').empty()
        $("<p class='alertText' style='color:red!important;'>" + robotOcpChartAlert + "</p>").appendTo('#alertrobotOcpChart')
        if(robotOcpChartAlert === '') {
            let newStateChartFilter4 = occupanyRobots;
                robotsOccupancFilterRequest(selectedDateStartDate3, selectedDateEndDate3, newStateChartFilter4);
        }
    }
        
