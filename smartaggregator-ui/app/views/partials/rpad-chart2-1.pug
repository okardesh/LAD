div.active#rpad-chart2-1

script.
    // DEFAULT GELEN ROBOTS OCCUPANCY RATE CHART VERILERI
    const occupanyRobots = JSON.parse('!{JSON.stringify(occupanyRobots)}');
    const dataRobots2 = [];

    let totalRobots2 = 0, totalFullTime = 0, totalFreeTime = 0
        occupanyRobots.forEach(function(element) {
            Object.keys(element).forEach(function(key) {
                if(key === 'hostMachineName'){
                    if(element[key] != null)
                        totalRobots2 = totalRobots2 + 1;
                } else if(key === 'fullTime'){
                    totalFullTime = totalFullTime + element[key];
                }
                else if(key ==='freeTime'){
                    totalFreeTime = totalFreeTime + element[key];
                }            
            });
        });
    let totalFullTimePercent = (parseInt(totalFullTime)/((parseInt(totalFullTime) + parseInt(totalFreeTime))/100));
    let totalFreeTimePercent = 100 - totalFullTimePercent;
    dataRobots2.push({
        type : "#{__('Full Time')} : %" + Math.round(totalFullTimePercent) + " - " + totalFullTime + " #{__('Minutes')}",
        value : totalFullTime,
        totalRobotsValue : totalRobots2
    });
    dataRobots2.push({
        type : "#{__('Free Time')} : %" + Math.round(totalFreeTimePercent) + " - " + totalFreeTime + " #{__('Minutes')}",
        value : totalFreeTime,
        totalRobotsValue : totalRobots2
    });

    const piePlot5 = new Pie('rpad-chart2-1', {
        appendPadding: [8, 18, 0, 18],
        data: dataRobots2,
        angleField: 'value',
        colorField: 'type',
        radius: 0.88,
        height: 270,
        innerRadius: 0.62,
        label: {
            type: 'inner',
            autoRotate: false,
            offset: '-45%',
            content: '',
            style: {
                textAlign: 'center',
                fontSize: 11,
                fill: '#111827',
                fontWeight: 600
            },
        },
        legend: {
            layout: 'vertical',
            position: 'bottom',
            itemName: {
                style: {
                    fontSize: 12,
                    fill: '#475467'
                }
            }
        },
        color: ['#62DAAB', '#FF4D4F',],
        interactions: [{ type: 'element-selected' }, { type: 'element-active' },{ type: 'element-highlight' }, { type: 'hover-cursor' }],
        statistic: {
                title: false,
                content: {
                style: {
                    whiteSpace: 'pre-wrap',
                    overflow: 'hidden',
                    textOverflow: 'ellipsis',
                },
                content: '',
            },
        },
        tooltip: {
            customContent: (title, data) => {
                let insideItem;
                if(data[0] != null || data[0] != undefined){
                    insideItem = data[0].data;
                    if(insideItem != null || insideItem != undefined){
                        return `<div class="tooltip-div">
                                    <h5 class="tooltip-header d-inline">#{__('Total')} ${insideItem.type} </h5></br>
                                    <h5 class="tooltip-header d-inline">#{__('Total')} Robot #{__('Counts')} : ${insideItem.totalRobotsValue}</h5>
                                </div>`;
                    }
                }
            }
        },
    });

    piePlot5.render();

    function renderOccupancyFromRows(rows){
        let newStateChart3 = [];
        if (rows && rows.length > 0) {
            $('#rpad-chart2-1').removeClass('visibility-none')
            let totalRobots2 = 0, totalFullTime = 0, totalFreeTime = 0
            rows.forEach(function(element) {
                Object.keys(element).forEach(function(key) {
                    if(key === 'hostMachineName'){
                        totalRobots2 = totalRobots2 + 1;
                    } else if(key === 'fullTime'){
                        totalFullTime = totalFullTime + (parseInt(element[key], 10) || 0);
                    }
                    else if(key ==='freeTime'){
                        totalFreeTime = totalFreeTime + (parseInt(element[key], 10) || 0);
                    }
                });
            });

            const totalMinutes = totalFullTime + totalFreeTime;
            const totalFullTimePercent = totalMinutes > 0 ? Math.round((totalFullTime / totalMinutes) * 100) : 0;
            const totalFreeTimePercent = totalMinutes > 0 ? Math.round((totalFreeTime / totalMinutes) * 100) : 0;

            newStateChart3.push({
                type : "#{__('Full Time')} : %" + totalFullTimePercent + " - " + totalFullTime + " #{__('Minutes')}",
                value : totalFullTime,
                totalRobotsValue : totalRobots2
            });
            newStateChart3.push({
                type : "#{__('Free Time')} : %" + totalFreeTimePercent + " - " + totalFreeTime + " #{__('Minutes')}",
                value : totalFreeTime,
                totalRobotsValue : totalRobots2
            });

            piePlot5.changeData(newStateChart3);
            piePlot5.render();
        } else {
            $('#rpad-chart2-1').addClass('visibility-none')
        }
    }

    function requestOccupancyPerRobotFallback(startTime, endTime, robots){
        const robotList = Array.isArray(robots) ? robots.filter(Boolean) : [];
        if (robotList.length === 0) {
            renderOccupancyFromRows([]);
            return;
        }

        const requests = robotList.map(function(robot){
            return new Promise(function(resolve){
                $.ajax({
                    url: "/robotsOccupancyRateChart2-filter",
                    type: 'POST',
                    data: { startTime: startTime, endTime: endTime, robots: [robot] },
                    dataType: 'json',
                    success: function(res){ resolve(res); },
                    error: function(){ resolve(null); }
                });
            });
        });

        Promise.all(requests).then(function(results){
            const mergedRows = [];
            results.forEach(function(item){
                if (item && item.rpadJobsList && item.rpadJobsList.length > 0) {
                    mergedRows.push.apply(mergedRows, item.rpadJobsList);
                }
            });
            if (mergedRows.length > 0) {
                renderOccupancyFromRows(mergedRows);
            } else {
                $.ajax({
                    url: "/robotsOccupancyRateChart-filter",
                    type: 'POST',
                    data: { startTime: startTime, endTime: endTime },
                    dataType: 'json',
                    success: function(res){
                        if (res && res.rpadJobsList && res.rpadJobsList.length > 0) {
                            renderOccupancyFromRows(res.rpadJobsList);
                        } else {
                            renderOccupancyFromRows([]);
                        }
                    },
                    error: function(){
                        renderOccupancyFromRows([]);
                    }
                });
            }
        });
    }

    // HER FILTRELEME ISLEMINDE GONDERILEN SORGU ISLEMINE AIT FONKSIYON
    function robotsOccupancFilterRequest(startTime, endTime, robots){
        filterRobotsOccupancyRateChart2 = {startTime:startTime, endTime : endTime, robots : robots};
        $.ajax({
            url: "/robotsOccupancyRateChart2-filter",
            type: 'POST',
            data: filterRobotsOccupancyRateChart2,
            dataType: 'json', // added data type
            success: function(res) {
                if(res && res.rpadJobsList && res.rpadJobsList.length > 0) {
                    renderOccupancyFromRows(res.rpadJobsList);
                } else {
                    requestOccupancyPerRobotFallback(startTime, endTime, robots);
                }
            },
            error: function(err){
                requestOccupancyPerRobotFallback(startTime, endTime, robots);
            }
        });
    }

    
    let responseControl2 = 0;
    // DATEPICKERLARDA OLAN HER DEGISIKLIKTE stateChartFilterFunction2 FONKSIYONUNUN TETIKLENDIGI KISIM
    $( window ).on( "load", function(){
        options = {
            format: "dd/mm/yyyy",
