div.active#rpad-chart1

script.
    const { Pie } = G2Plot;
    const rpadStateChart = JSON.parse('!{JSON.stringify(rpadStateChart)}');
    const data6 = [];
    rpadStateChart.sort((a, b) => a.state - b.state).forEach(element => {
        data6.push({
            state : `${element.state} sayısı = ${element.count}`,
            count : element.count,
            content: {
                count: element.count !=null ? currencyFormat2.format(element.count) : 0,
                state: element.state, 
                }
        })
    });
    
    const piePlot = new Pie('rpad-chart1', {
        appendPadding: 70,
        data: data6,
        angleField: 'count',
        colorField: 'state',
        radius: 1,
        height: 545,
        innerRadius: 0.5,
        label: {
            type: 'inner',
            autoRotate: false,
            offset: '-50%',
            content: '',
            style: {
                textAlign: 'center',
                fontSize: 12,
                fill: 'black',
                fontWeight: 600
            },
        },
        legend: {
            layout: 'vertical',
            position: 'bottom'
        },
        color: ['#FF4D4F', '#6395F9', '#62DAAB'],
        interactions: [{ type: 'element-selected' }, { type: 'element-active' },{ type: 'element-highlight' }, { type: 'hover-cursor' }],
        statistic: {
                title: false,
                content: {
                style: {
                    whiteSpace: 'pre-wrap',
                    overflow: 'hidden',
                    textOverflow: 'ellipsis',
                },
                content: '',
            },
        },
        tooltip: {
            customContent: (title, data) => {
                let insideItem;
                if(data[0] != null || data[0] != undefined){
                    insideItem = data[0].data;
                    if(insideItem.content != null || insideItem.content != undefined){
                        return `<div class="tooltip-div">
                                <h5 class="tooltip-header">TOPLAM ${insideItem.content.state} Sayısı : </h5><h5 class="tooltip-content">${insideItem.content.count}</h5>
                            </div>`;
                    }
                }
            }
        },
    });

    piePlot.render();

    $('input[name="endTimeStateChart"]').on('change', function(){
        let selectedDateStartDate = $(startTimeStateChart).val();
        let selectedDateEndDate = $(endTimeStateChart).val();
        if(selectedDateStartDate === 'Start Date' || selectedDateStartDate === 'Başlangıç Tarihi'){
            alert('please enter start date first')
        }else if(selectedDateEndDate < selectedDateStartDate){
            alert('start date must be greater than end date')
        }else{
            $('input[name="selectedDateStartDate"]').attr('value', selectedDateStartDate)
            $('input[name="selectedDateEndDate"]').attr('value', selectedDateEndDate)


            filterStateChart = {startTime:selectedDateStartDate, endTime : selectedDateEndDate};

            $.ajax({
                url: "/rpadStateChart-filter",
                type: 'POST',
                data: filterStateChart,
                dataType: 'json', // added data type
                success: function(res) {
                    let newData6 = [];
                    if(res.rpadJobsList.length > 0) {
                        $('#rpad-chart1').removeClass('visibility-none')
                            res.rpadJobsList.sort((a, b) => a.state - b.state).forEach(element => {
                                newData6.push({
                                    state : `${element.state} sayısı = ${element.count}`,
                                    count : element.count,
                                    content: {
                                        count: element.count !=null ? currencyFormat2.format(element.count) : 0,
                                        state: element.state, 
                                        }
                            })
                        });
                        piePlot.changeData(newData6);
                        piePlot.render();
                    }else{
                        $('#rpad-chart1').addClass('visibility-none')
                    }
                },
                error: function(err){
                    console.log('error')
                }
            });
        }
    })

