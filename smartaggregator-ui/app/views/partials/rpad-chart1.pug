        $.ajax({
                url: "/rpadStateChart-filter",
                type: 'POST',
                data: filterStateChart,
                dataType: 'json', // added data type
                success: function(res) {
                    let newData6 = [];
                    if(res.rpadJobsList.length > 0) {
                        $('#rpad-chart1').removeClass('visibility-none')
                            res.rpadJobsList.sort((a, b) => a.state - b.state).forEach(element => {
                                newData6.push({
                                    state : `${element.state} sayısı = ${element.count}`,
                                    count : element.count,
                                    content: {
                                        count: element.count !=null ? currencyFormat2.format(element.count) : 0,
