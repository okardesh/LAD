    $('input[name="last-week2"]').on('click', function(){
        var lastWeekEnd = new Date();
        var lastDataDate = $('input[name="workDate"]').val();
        
        let newlastDataDay = lastDataDate.slice(0, 2);
        let newlastDataMonth = lastDataDate.slice(3, 5);
        let newlastDataYear = lastDataDate.slice(6, 10);
        lastDataDate = new Date(newlastDataYear + '-' + newlastDataMonth + '-' + newlastDataDay);

        for(let i=0; i < 7 ; i++){
            lastWeekEnd = new Date(lastDataDate - 1000 * 60 * 60 * 24 * i);
            if(lastWeekEnd.getUTCDay() == 0){
                break;
            }
        }

        let lastWeekStart = new Date(lastWeekEnd - 1000 * 60 * 60 * 24 * 6);

        var lastWeekEndFormat = new Date(lastWeekEnd);
        lastWeekEndFormat =
            ('0' + lastWeekEndFormat.getDate()).slice(-2) + '/' + 
            ('0' + (lastWeekEndFormat.getMonth()+1)).slice(-2) + '/' + 
            lastWeekEndFormat.getFullYear();


        var lastWeekStartFormat = new Date(lastWeekStart);

        lastWeekStartFormat =
             ('0' + lastWeekStartFormat.getDate()).slice(-2) + '/' + 
            ('0' + (lastWeekStartFormat.getMonth()+1)).slice(-2) + '/' + 
            lastWeekStartFormat.getFullYear();




        $('input[name="startTimeStateChart"]').attr('value', lastWeekStartFormat)
        $('input[name="endTimeStateChart"]').attr('value', lastWeekEndFormat)



        filterStateChart = {startTime:lastWeekStartFormat, endTime : lastWeekEndFormat};
        $.ajax({
                url: "/rpadStateChart-filter",
