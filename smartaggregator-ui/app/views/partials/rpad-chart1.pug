        var MonthDate = new Date();
        var firstDay = new Date(new Date().getFullYear(), 0, 1);
        

        var newfirstYear = firstDay.getFullYear();
        var newfirstMonth = firstDay.getMonth()+1;
        var newfirstDay = firstDay.getDate();

        var fullFirstDay = ('0' + newfirstDay).slice(-2) + '/' + ( '0' + newfirstMonth).slice(-2) + '/' + newfirstYear;


