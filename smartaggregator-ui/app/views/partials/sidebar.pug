    script.
        $(document).ready(function() {
            if($('.mainMenu a[href^="/' + location.pathname.split("/")[1] + '"]').parents('.subMenu').length > 0){
                $('.mainMenu a[href="/' + location.pathname.split("/")[1] + '"]').addClass('current-pages');
                $('.mainMenu a[href="/' + location.pathname.split("/")[1] + '"]').parents('.item-header').addClass('selectedmenu');
                var li_id = $('.subMenu a[href^="/' + location.pathname.split("/")[1] + '"]').parents('li').attr('id');
                if(document.location.href.indexOf("#") != -1) {
                    var url = document.location.href;
                    document.location = url;
                }else{
                    var url = document.location.href+"#"+li_id;
                    document.location = url;
                }
            }
            else{
                $('a[href^="/' + location.pathname.split("/")[1] + '"]').addClass('main-current-page');
            }

            $( ".item-header" ).on('click', function(e){
                 if($(".selectedmenu").length >=1){
                     for(let i =0 ; i<$(".selectedmenu").length; i++){
                         if(e.currentTarget.id.toString() != $(".selectedmenu")[i].id.toString()){
                             $(".selectedmenu").removeClass("selectedmenu");
                         }
                     }
                 }
                $(this).toggleClass('selectedmenu');
                setTimeout(function(){
                    var elmnt = document.getElementById("sidebarId");
                    elmnt.scrollIntoView();
                }, 0)
               
            });


        });            
