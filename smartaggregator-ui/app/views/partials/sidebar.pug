    aside.left-sidebar(data-sidebarbg='skin6')
        // Sidebar scroll
        .scroll-sidebar(data-sidebarbg='skin6')
            .sidebar-container#sidebarId
                ui.mainMenu
                    li#dashboard.item-header
                        a.item-btn(href='#dashboard')
                            span.hide-menu #{__('Dashboard')}
                            i.hide-menu.button--i.float-right(type="button", data-feather='chevron-down')
