    $('select[name="states2"]').on('change', function(){
        let newStateChartFilter2 = $('select[name="states2"]').val();
        filterRobotsOccupancyRateChart2 = {ReleaseName : newStateChartFilter2};
            $.ajax({
                url: "/robotsOccupancyRateChart2-filter",
                type: 'POST',
                data: filterRobotsOccupancyRateChart2,
                dataType: 'json', // added data type
                success: function(res) {
                    let newStateChart2 = [];
                    if(res.rpadJobsList.length > 0) {
                        $('#rpad-chart2').removeClass('visibility-none')
                            res.rpadJobsList.sort((a, b) => a.state - b.state).forEach(element => {
                                newStateChart2.push({
                                    state : `${element.state} sayısı = ${element.count}`,
                                    count : element.count,
                                    content: {
                                        count: element.count !=null ? currencyFormat2.format(element.count) : 0,
                                        state: element.state, 
                                        }
                            })
                        });
                        piePlot.changeData(newStateChart);
                        piePlot.render();
                    }else{
                        $('#rpad-chart2').addClass('visibility-none')
                    }
                    
                },
                error: function(err){
                    console.log('error')
                }
            });
    });

    $('input[name="last-working-date"]').on('click', function(){
        var lastWorkingDate = new Date();
        var lastDataDate = $('input[name="workDate"]').val();
        
        let newlastDataDay = lastDataDate.slice(0, 2);
        let newlastDataMonth = lastDataDate.slice(3, 5);
        let newlastDataYear = lastDataDate.slice(6, 10);
        lastDataDate = new Date(newlastDataYear + '-' + newlastDataMonth + '-' + newlastDataDay);

        for(let i=0; i < 7 ; i++){
            lastWorkingDate = new Date(lastDataDate - 1000 * 60 * 60 * 24 * i);
            if(lastWorkingDate.getUTCDay() > 0 && lastWorkingDate.getUTCDay() < 6){
                break;
            }
        }

        var lastWorkingDateToday = new Date(lastWorkingDate);

        var allLastWorkingDateTodayDay = 
            ('0' + lastWorkingDateToday.getDate()).slice(-2) + '/' + 
            ('0' + (lastWorkingDateToday.getMonth()+1)).slice(-2) + '/' + 
            lastWorkingDateToday.getFullYear();


        $('input[name="startTime2"]').attr('value', allLastWorkingDateTodayDay)
        $('input[name="endTime2"]').attr('value', allLastWorkingDateTodayDay)



        filterRobotsOccupancyRateChart = {startTime:allLastWorkingDateTodayDay, endTime : allLastWorkingDateTodayDay};
        $.ajax({
            url: "/robotsOccupancyRateChart-filter",
            type: 'POST',
            data: filterRobotsOccupancyRateChart,
            dataType: 'json', // added data type
            success: function(res) {
