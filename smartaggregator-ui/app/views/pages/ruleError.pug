extends ../layout

block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/sidebar

        .page-wrapper
            .page-breadcrumb
                .row
                    .col-md-5.col-lg-4.align-self-center
                        h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Rule Error')}
                        .d-flex.align-items-center
                            nav(aria-label='breadcrumb')
                                ol.breadcrumb.m-0.p-0
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/') #{__('Home')}
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/rule-errors') #{__('Rule Errors')}
                                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Rule Error')}
                    .col-md-7.col-lg-8
                        .row.justify-content-end
                            .col-xl-5
                                .row.justify-content-end
                                    .col-md-6
                                        button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                                            i.fas.fa-download
                                            |  #{__('Export')}
                                    .col-md-6
                                        button.allDataExportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='allDataExport', value='xlsx')
                                            i.fas.fa-download
                                            |  #{__('All Data Export')}
                .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
            .container-fluid.p-3
                    .row
                        .col-12
                            .card
                                .card-body
                                    .table-responsive.dragscroll
                                        table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                            thead
                                                tr
                                                    th(data-name='batchIndex', data-type='amount', data-searchable='on', data-sortable='on') #{__('incorrectRowNumber')}
                                                    th(data-name='ruleName', data-searchable='on', data-sortable='on') #{__('Name')}
                                                    th(data-name='ruleDescription', data-searchable='on', data-sortable='on') #{__('Description')}
                                                    th(data-name='conditionKey', data-searchable='on', data-sortable='on') #{__('Key')}
                                                    th(data-name='conditionOperator', data-searchable='on', data-sortable='on') #{__('Operator')}
                                            if ruleError.pageItems
                                                tbody
                                                    each item in ruleError.pageItems.content
                                                        tr
                                                            td=item.batchIndex
                                                            td
                                                                if item.ruleName
                                                                    each text in item.ruleName.split(' || ')
                                                                        p #{__(text)}
                                                            td
                                                                if item.ruleDescription
                                                                    a.descript-detail(href='javascript:void(0)')&attributes({'data-content': uCanTrust(item.ruleDescription), 'data-class': 'xl',})
                                                                        i.fa.fa-paperclip
                                                                        |  #{__('Detail')}
                                                            td=item.conditionKey
                                                            td=item.conditionOperator
                                    +pagination(ruleError.pageItems)
