extends ../layout

block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/sidebar

        .page-wrapper
            .page-breadcrumb
                .row
                    .col-md-5.col-lg-4.align-self-center
                        h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Reconciliation Check Errors Page')}
                        .d-flex.align-items-center
                            nav(aria-label='breadcrumb')
                                ol.breadcrumb.m-0.p-0
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/') #{__('Home')}
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/reconciliation-check-errors') #{__('Reconciliation Check Errors Page')}
                                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Reconciliation Check Error')}
                    .col-md-7.col-lg-8
                        .row.justify-content-end
                            .col-xl-5
                                .row.justify-content-end
                                    .col-md-6
                                        button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                                            i.fas.fa-download
                                            |  #{__('Export')}
                                    .col-md-6
                                        button.allDataExportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='allDataExport', value='xlsx')
                                            i.fas.fa-download
                                            |  #{__('All Data Export')}
                .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
            .container-fluid.p-3
                .row
                    .col-12
                        .card
                            .card-body
                                .table-responsive.dragscroll
                                    table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                        thead
                                            tr
                                                th(data-name='reconciliationCheckSubject',data-searchable='on', data-sortable='on') #{__('subject')}
                                                th(data-name='message',data-searchable='on') #{__('error.m.control')}
                                                th #{__('Query')}
                                                th #{__('Type')}
                                                th(data-name='count', data-type='number' data-searchable='on', data-sortable='on') #{__('incorrectEntriesCount')}
                                        if reconciliationCheckError.pageItems
                                            tbody
                                                each item in reconciliationCheckError.pageItems.content
                                                    tr.notorder
                                                        td=reconciliationCheckSubject(item.reconciliationCheckSubject)
                                                        td
                                                            if item.message
                                                                each text in item.message.split(' || ')
                                                                    p= text
                                                        td
                                                            if item.query
                                                                a.descript-detail(href='javascript:void(0)')&attributes({'data-content': uCanTrust(item.query), 'data-class': 'xl', 'data-contenttype': 'sql'})
                                                                    i.fa.fa-paperclip
                                                                    |  #{__('Detail')}
                                                        td=reconciliationCheckType(item.type)
                                                        td.text-right=item.count
                                +pagination(reconciliationCheckError.pageItems)                        
