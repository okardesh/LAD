                                        i.fas.fa-info-circle(style="margin-right:5px;margin-left:-10px;color:royalblue")
                                            | #{__('Data History')}

                        .card-body
                            .table-responsive.dragscroll
                                table#ruleTable.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                    thead
                                        tr
                                            th
                                            th #{__('Query')}
                                            th #{__('Last Updated By')}
                                            th #{__('Last Updated Time')}
                                    tbody
                                     each item in trendAnalysis.history
                                        tr
                                            td
                                            td
                                              .sql-editor(contenteditable='true')= trendAnalysis.query
