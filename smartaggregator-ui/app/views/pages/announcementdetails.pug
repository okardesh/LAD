extends ../layout

block content
  #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
    include ../partials/header
    include ../partials/sidebar
      
    .page-wrapper
      .page-breadcrumb
        .row
          .col-md-6.col-lg-5.col-xl-4.align-self-center
            h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Announcements')}
            .d-flex.align-items-center
              nav(aria-label='breadcrumb')
                ol.breadcrumb.m-0.p-0
                  li.breadcrumb-item
                    a.text-muted.active-link(href='/') #{__('Home')}
                  li.breadcrumb-item
                    a.text-muted.active-link(href='/announcements') #{__('Announcements')}
                  li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Announcement')}
          .col-md-6.col-lg-7.col-xl-8
            form(id='user', method='POST')
              input(type='hidden', name='_csrf', value=_csrf)
              .row.justify-content-end
                .col-sm-6.col-md-12.col-lg-6
                  .row.justify-content-end
                    .col-6
                      button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                        i.fas.fa-download
                        |  #{__('Export')}
        .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
      .container-fluid.p-3
        .row
          .col-12
            .card
              .card-body
                .table-responsive.dragscroll
                  table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                    thead
                      tr
                        th.notexport
                        th #{__('NameSurname')}
                        th #{__('FormalName')}
                        th #{__('IsRead')}
                        if announcement.enableAccept === 1
                          th #{__('IsAccept')}
                    if announcementdetails
                      tbody
                        each announcementdetail in announcementdetails
                          if announcementdetail.isAccept === 1
                            tr
                              td
                              td=announcementdetail.nameSurname
                              td=announcementdetail.subsidiaryFormalName
                              td=announcementdetail.isRead === 1 ? __('Yes') : __('No')
                              if announcement.enableAccept === 1
                                td=announcementdetail.isAccept === 1 ? __('Yes') : __('No')
                          else
                            tr
                              td
                              td.font-weight-bold=announcementdetail.nameSurname
                              td.font-weight-bold=announcementdetail.subsidiaryFormalName
                              td.font-weight-bold=announcementdetail.isRead === 1  ?  __('Yes'): __('No')
                              if announcement.enableAccept === 1
                                td.font-weight-bold=announcementdetail.isAccept === 1  ? __('Yes') : __('No')

