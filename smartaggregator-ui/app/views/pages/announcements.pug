extends ../layout

block content
  #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
    include ../partials/header
    include ../partials/sidebar
      
    .page-wrapper
      .page-breadcrumb
        .row
          .col-md-6.col-lg-5.col-xl-4.align-self-center
            h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Announcements')}
             if(user.rolePermissionAll.includes('/v1/documents/files/{screenCode}_GET'))
              a.statistic-btn(href="#", onclick=`openPopupDocuments()`)
                .far.fa-file
                  
            .d-flex.align-items-center
              nav(aria-label='breadcrumb')
                ol.breadcrumb.m-0.p-0
                  li.breadcrumb-item
                    a.text-muted.active-link(href='/') #{__('Home')}
                  li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Announcements')}
          .col-md-6.col-lg-7.col-xl-8
            form(id='user', method='POST')
              input(type='hidden', name='_csrf', value=_csrf)
              .row.justify-content-end
                .col-sm-6.col-md-12.col-lg-6
                  .row.justify-content-end
                    if user.rolePermissionAll.includes('/v1/announcement_POST')
                      .col-6
                        button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='submit', name='action', value='new')
                          i.fas.fa-plus
                          |  #{__('New')}
                    .col-6
                      button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                        i.fas.fa-download
                        |  #{__('Export')}
        .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
      .container-fluid.p-3
        .row
          .col-12
            .card
              .card-body
                .table-responsive.dragscroll
                  table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                    thead
                      tr
                        th.notexport
                        th.notexport
                        th(data-name='subject', data-searchable='on', data-sortable='on') #{__('Subject')}
                        th(data-name='lastUpdatedTime',data-type="date", data-searchable='on', data-sortable='on') #{__('AnnouncementDate')}

                    if announcements
                      tbody
                        each announcement in announcements.content
                          tr
                            td.text-center
                              a(href='/announcement/' + announcement.uuid)
                                i.fas.fa-eye.fa-2x
                            td.text-center
                              a(href='/announcement-details/' + announcement.uuid)
                                i.fas.fa-info-circle.fa-2x(style='color:#FFD700')
                            td=announcement.subject
                            td=announcement.lastUpdatedTime

                +pagination(announcements)
              script.
                function openPopupDocuments() {
                  getFilesWindow("ANNOUNCEMENTS");
                }

