                            let qttEndTime = $("#qttEndTime").val()
                            let queueRobots = $("#queueRobots").val()
                            let queueNames = $("#queueNames").val()
                            let queueNameString = queueNames.join(", ");
                            let robotNameString = queueRobots.join(", ");
                            let queueRobotNames = queueNameString + "|" + robotNameString
                            var chart8 = {
                                uuid : userId,
                                chartName : "chart8",
                                robots : queueRobotNames,
                                date1: qttStartTime,
                                date2: qttEndTime
                            }
                            let queueStatusStartTime = $("#queueStatusStartTime").val()
                            let queueStatusEndTime = $("#queueStatusEndTime").val()
                            let queueStatusNames = $("#queueStatusNames").val()
                            let queueStatusNamesString = queueStatusNames.join(", ")
                            var chart9 = {
                                uuid : userId,
                                chartName : "chart9",
                                robots : queueStatusNamesString,
                                date1: queueStatusStartTime,
                                date2: queueStatusEndTime
                            }
                            chartData.push(chart1, chart2, chart3, chart4, chart5, chart6, chart8, chart9)
                            savedChartFilters = {historyList: chartData}

                            $.ajax({
                                url: "/rpad-history",
                                type: 'POST',
                                data: savedChartFilters,
                                dataType: 'json',
                                success: function (res) {
                                    console.log(`send process is successful`)
                                },
                                error: function (xhr, status, error) {
                                    console.error(`error message : ${error}\nerror status : ${status}\nerror xhr : ${xhr}`)
                                }
                            })
                        });

                        $(".datepicker2").toArray().forEach(function (inp) {
                            var $this = $(inp),
                                options2 = {
                                    format: "dd/mm/yyyy",
                                    orientation: 'bottom left',
                                    language: locale,
                                };
                            $this.datepicker(options2);
                        });
                    });



                    $(window).on("load",function () {
                        $('#exampleModal').on('hide.bs.modal', function () {
                            if (document.activeElement && typeof document.activeElement.blur === 'function') {
                                document.activeElement.blur();
                            }
                        });

                        const arrangement = JSON.parse('!{JSON.stringify(arrangement)}')
                        const rpadChartsStatusList = arrangement && arrangement.rpadChartsStatusList ? arrangement.rpadChartsStatusList : [];
                        let currentOrder = []
                        for (let i=0;i<8;i++){
                            currentOrder.push(rpadChartsStatusList[i] ? rpadChartsStatusList[i].location : i)
                        }
                        $("#sortable .chart-div").sort(function(a, b) {
                            return $(a).data("position") - $(b).data("position");
                        }).appendTo("#bout");
                        $("#sortable .chart-div").sort(function(a, b) {
                            // İki div'in data-order değerlerini al
                            let aOrder = $(a).data("order");
                            let bOrder = $(b).data("order");

                            return currentOrder.indexOf(aOrder) - currentOrder.indexOf(bOrder);
                        }).appendTo("#sortable");


                        for (let i = 0; i < rpadChartsStatusList.length; i++) {
                            if (!rpadChartsStatusList[i].chartStatus) {
                                const chartDivId = `chart-${i + 1}-div`;
                                $('#' + chartDivId).addClass('d-none');
                            }
                        }

                    })