                        // Print whole page part
                        $("#btn").click(function () {
                            domtoimage.toJpeg(document.getElementById('allChartsPrint'), { quality: 1 })
                                .then(function (dataUrl) {
                                    var link = document.createElement('a');
                                    link.download = 'RPA Dashboard.png';
                                    link.href = dataUrl;
                                    link.click();
