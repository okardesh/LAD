                script.
                    function openPopupDocuments() {
                        getFilesWindow("FMU");}
                    
                    const userId = JSON.parse('!{JSON.stringify(userId)}')

                    $(document).ready(function() {

                        $('#dashboardFilterBtn').on('click', function () {
                            $('.page-wrapper').toggleClass('dashboard-filters-open');
                            $(this).toggleClass('primary');
                            if (!$('.page-wrapper').hasClass('dashboard-filters-open')) {
                                $(this).addClass('primary');
                            }
                        });

                        function chartDivSelector(chartNo) {
                            return '#chart-' + chartNo + '-div';
                        }

                        function setChartVisibility(chartNo, visible) {
                            const sel = chartDivSelector(chartNo);
                            if (visible) {
                                $(sel).removeClass('d-none');
                            } else {
                                $(sel).addClass('d-none');
                            }
                        }

                        function setDrawerButtonState(chartNo, visible) {
                            const showBtn = $('.cfg-act-btn[data-chart="' + chartNo + '"][data-state="show"]');
                            const hideBtn = $('.cfg-act-btn[data-chart="' + chartNo + '"][data-state="hide"]');
                            showBtn.toggleClass('active', visible);
                            hideBtn.toggleClass('active', !visible);
                        }

                        function syncDrawerFromDashboard() {
                            [1,2,3,4,5,8,9].forEach(function (no) {
                                const visible = !$(chartDivSelector(no)).hasClass('d-none');
                                setDrawerButtonState(no, visible);
                            });

                            const robotAnyVisible = [1,2,3,4,5].some(function (no) {
                                return !$(chartDivSelector(no)).hasClass('d-none');
                            });
                            const processAnyVisible = [8,9].some(function (no) {
                                return !$(chartDivSelector(no)).hasClass('d-none');
                            });
                            $('#cfg-section-robot').prop('checked', robotAnyVisible);
                            $('#cfg-section-process').prop('checked', processAnyVisible);
                        }

                        function openDashboardConfig() {
                            syncDrawerFromDashboard();
                            $('#dashboardConfigBackdrop').addClass('open');
                            $('#dashboardConfigPanel').addClass('open');
                            feather.replace();
                        }

                        function closeDashboardConfig() {
                            $('#dashboardConfigBackdrop').removeClass('open');
                            $('#dashboardConfigPanel').removeClass('open');
                        }

                        $('#dashboardEditBtn').on('click', function () {
                            openDashboardConfig();
                        });

                        $('#dashboardConfigClose, #dashboardConfigBackdrop').on('click', function () {
                            closeDashboardConfig();
                        });

                        $('.cfg-act-btn').on('click', function () {
                            const chartNo = parseInt($(this).attr('data-chart'), 10);
                            const state = $(this).attr('data-state');
                            const visible = state === 'show';
                            setChartVisibility(chartNo, visible);
                            setDrawerButtonState(chartNo, visible);
                        });

                        $('#cfg-section-robot').on('change', function () {
                            const visible = $(this).is(':checked');
                            [1,2,3,4,5].forEach(function (no) {
                                setChartVisibility(no, visible);
                                setDrawerButtonState(no, visible);
                            });
                        });

                        $('#cfg-section-process').on('change', function () {
                            const visible = $(this).is(':checked');
                            [8,9].forEach(function (no) {
                                setChartVisibility(no, visible);
                                setDrawerButtonState(no, visible);
                            });
                        });

                        $('#dashboardConfigSave').on('click', function () {
                            const userIdForSave = userId;
                            const order = [];
                            $('#sortable .chart-div').each(function () {
                                const n = parseInt($(this).attr('data-order'), 10);
                                if (!Number.isNaN(n)) order.push(n);
                            });

                            function chartStatusByNo(no) {
                                return !$(chartDivSelector(no)).hasClass('d-none');
                            }
                            function locationByNo(no, fallback) {
                                const idx = order.indexOf(no);
                                return idx >= 0 ? (idx + 1) : fallback;
                            }

                            const payload = {
                                chartsStatusList: [
                                    {uuid: userIdForSave, chartName: 'chart1', chartStatus: chartStatusByNo(1), location: locationByNo(1, 1)},
                                    {uuid: userIdForSave, chartName: 'chart2', chartStatus: chartStatusByNo(2), location: locationByNo(2, 2)},
                                    {uuid: userIdForSave, chartName: 'chart3', chartStatus: chartStatusByNo(3), location: locationByNo(3, 3)},
                                    {uuid: userIdForSave, chartName: 'chart4', chartStatus: chartStatusByNo(4), location: locationByNo(4, 4)},
                                    {uuid: userIdForSave, chartName: 'chart5', chartStatus: chartStatusByNo(5), location: locationByNo(5, 5)},
                                    {uuid: userIdForSave, chartName: 'chart6', chartStatus: chartStatusByNo(6), location: locationByNo(6, 6)},
                                    {uuid: userIdForSave, chartName: 'chart8', chartStatus: chartStatusByNo(8), location: locationByNo(8, 7)},
                                    {uuid: userIdForSave, chartName: 'chart9', chartStatus: chartStatusByNo(9), location: locationByNo(9, 8)}
                                ]
                            };

                            $.ajax({
                                url: '/rpad-charts-status-save',
                                type: 'POST',
                                data: payload,
                                dataType: 'json',
                                complete: function () {
                                    closeDashboardConfig();
                                }
                            });
                        });

                        $('.datepicker2').datepicker({
                            format: "dd/mm/yyyy",
                            orientation: 'bottom left',
                            language: locale,
                            autoclose: true,
                        });


                        $('.js-example-basic-multiple').select2();
                        $('.js-example-basic-single').select2();
                        $("#checkbox").click(function(){
                            $(".js-example-basic-multiple > option").prop("selected","selected");
                            $(".js-example-basic-multiple").trigger("change");
                        });
                        $("#deleteButton").click(function () {
                            $(".js-example-basic-multiple").val(null).trigger("change");
                        });

                        $('.js-example-basic-multiple2').select2();
                        $("#checkbox2").click(function(){
                            $(".js-example-basic-multiple2 > option").prop("selected","selected");
                            $(".js-example-basic-multiple2").trigger("change");
                        });
                        $("#deleteButton2").click(function () {
                            $(".js-example-basic-multiple2").val(null).trigger("change");
                        });

                        $('.js-example-basic-multiple3').select2();
                        $("#checkbox3").click(function(){
                            $(".js-example-basic-multiple3 > option").prop("selected","selected");
                            $(".js-example-basic-multiple3").trigger("change");
                        });
                        $("#deleteButton3").click(function () {
                            $(".js-example-basic-multiple3").val(null).trigger("change");
                        });

                        $('.js-example-basic-multiple-chart3').select2();
                        $("#checkbox-chart3").click(function(){
                            $(".js-example-basic-multiple-chart3 > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart3").trigger("change");
                        });
                        $("#deleteButton-chart3").click(function () {
                            $(".js-example-basic-multiple-chart3").val(null).trigger("change");
                        });

                        $('.js-example-basic-multiple-chart4').select2();
                        $("#checkbox-chart4").click(function(){
                            $(".js-example-basic-multiple-chart4 > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart4").trigger("change");
                        });
                        $("#deleteButton-chart4").click(function () {
                            $(".js-example-basic-multiple-chart4").val(null).trigger("change");
                        });

                        $('.js-example-basic-multiple-chart5').select2();
                        $("#checkbox-chart5").click(function(){
                            $(".js-example-basic-multiple-chart5 > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart5").trigger("change");
                        });
                        $("#deleteButton-chart5").click(function () {
                            $(".js-example-basic-multiple-chart5").val(null).trigger("change");
                        });
                        $('.js-example-basic-multiple-chart8-robot').select2();
                        $("#checkbox-chart8-robot").click(function(){
                            $(".js-example-basic-multiple-chart8-robot > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart8-robot").trigger("change");
                        });
                        $("#deleteButton-chart8-robot").click(function () {
                            $(".js-example-basic-multiple-chart8-robot").val(null).trigger("change");
                        });
                        $('.js-example-basic-multiple-chart8-queue').select2();
                        $("#checkbox-chart8-queue").click(function(){
                            $(".js-example-basic-multiple-chart8-queue > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart8-queue").trigger("change");
                        });
                        $("#deleteButton-chart8-queue").click(function () {
                            $(".js-example-basic-multiple-chart8-queue").val(null).trigger("change");
                        });
                        $('.js-example-basic-multiple-chart9-queue').select2();
                        $("#checkbox-chart9-queue").click(function(){
                            $(".js-example-basic-multiple-chart9-queue > option").prop("selected","selected");
                            $(".js-example-basic-multiple-chart9-queue").trigger("change");
                        });
                        $("#deleteButton-chart9-queue").click(function () {
                            $(".js-example-basic-multiple-chart9-queue").val(null).trigger("change");
                        });
                        // Print whole page part
                        function downloadDashboardImage(dataUrl) {
                            var link = document.createElement('a');
                            link.download = 'RPA Dashboard.png';
                            link.href = dataUrl;
                            link.click();
                        }

                        function exportWithHtml2Canvas(el) {
                            return html2canvas(el, {
                                useCORS: true,
                                allowTaint: true,
                                backgroundColor: '#f5f6f8',
                                scale: 2,
                                logging: false
                            }).then(function (canvas) {
                                return canvas.toDataURL('image/png');
                            });
                        }

                        $("#dashboardExportBtn").off('click.rpadExport').on('click.rpadExport', function () {
                            var exportBtn = $(this);
                            var exportTarget = document.getElementById('allChartsPrint');
                            if (!exportTarget) return;

                            exportBtn.prop('disabled', true);

                            var exportPromise;
                            if (typeof domtoimage !== 'undefined' && domtoimage.toPng) {
                                exportPromise = domtoimage.toPng(exportTarget, {
                                    quality: 1,
                                    cacheBust: true,
                                    bgcolor: '#f5f6f8'
                                });
                            } else {
                                exportPromise = exportWithHtml2Canvas(exportTarget);
                            }

                            exportPromise
                                .then(function (dataUrl) {
                                    downloadDashboardImage(dataUrl);
                                })
                                .catch(function () {
                                    return exportWithHtml2Canvas(exportTarget).then(function (dataUrl) {
                                        downloadDashboardImage(dataUrl);
                                    });
                                })
                                .catch(function () {
                                    $.alert({
                                        title: 'Hata',
                                        content: 'Dışa aktarma işlemi başarısız oldu. Lütfen tekrar deneyin.'
                                    });
                                })
                                .finally(function () {
                                    exportBtn.prop('disabled', false);
                                });
                        });

                        //- Status chart default date - first day of the month to last day of the month
                        //$('button[name="last-working-date3"]').trigger( "click" );

                        //- Robots occupancy rate chart - first day of the month to last day of the month
                        //$('button[name="last-working-date4"]').trigger( "click" );
                        

                        //chartların içindeki filtreleri kaydedildiği yer
                        $("input, select").on("change", function () {
                            //veriler burada depolanacak.
                            var chartData = []
                            let startTimeStateChartDatePicker = $("#startTimeStateChartDatePicker").val()
                            let endTimeStateChartDatePicker = $("#endTimeStateChartDatePicker").val()
                            let statesRobots = $("#statesRobots").val()
                            let selectedRobotsString = statesRobots.join(", ");
                            var chart1 = {
                                uuid : userId,
                                chartName : "chart1",
                                robots : selectedRobotsString,
                                date1: startTimeStateChartDatePicker,
                                date2: endTimeStateChartDatePicker
                            }
                            let startTimeRobotsOccupancyRateDatePicker = $("#startTimeRobotsOccupancyRateDatePicker").val()
                            let endTimeRobotsOccupancyRateDatePicker = $("#endTimeRobotsOccupancyRateDatePicker").val()
                            let occupanyRobots = $('#occupanyRobots').val()
                            let occupanyRobotsString = occupanyRobots.join(", ")
                            var chart2 = {
                                uuid: userId,
                                chartName : "chart2",
                                robots : occupanyRobotsString,
                                date1 : startTimeRobotsOccupancyRateDatePicker,
                                date2 : endTimeRobotsOccupancyRateDatePicker
                            }
                            let workDate = $("#workDate").val();
                            let whoRobots = $("#whoRobots").val()
                            let whoRobotsString = whoRobots.join(", ")
                            var chart3 = {
                                uuid : userId,
                                chartName : "chart3",
                                robots : whoRobotsString,
                                date1 : workDate,
                                date2 : null
                            }
                            let startTime = $("#startTime").val()
                            let endTime = $("#endTime").val()
                            let wdRobots = $("#wdRobots").val()
                            let wdRobotsString = wdRobots.join(", ")
                            var chart4 = {
                                uuid : userId,
                                chartName : "chart4",
                                robots : wdRobotsString,
                                date1: startTime,
                                date2: endTime
                            }
                            let workDate2 = $("#workDate2").val()
                            let odwRobots = $("#odwRobots").val()
                            let odwRobotsString = odwRobots.join(", ")
                            var chart5 = {
                                uuid : userId,
                                chartName : "chart5",
                                robots : odwRobotsString,
                                date1 : workDate2,
                                date2: null
                            }
                            let releaseTotalTimeChart_year = $("#releaseTotalTimeChart_year").val()
                            let releaseTotalTimeChart_month = $("#releaseTotalTimeChart_month").val()
                            let releaseRobots = $("#releaseRobots").val()
                            let releaseRobotsString = releaseRobots.join(", ")
                            var chart6 = {
                                uuid : userId,
                                chartName : "chart6",
                                robots : releaseRobotsString,
                                date1 : releaseTotalTimeChart_year,
                                date2 : releaseTotalTimeChart_month
                            }
                            let qttStartTime = $("#qttStartTime").val()
                            let qttEndTime = $("#qttEndTime").val()
                            let queueRobots = $("#queueRobots").val()
                            let queueNames = $("#queueNames").val()
                            let queueNameString = queueNames.join(", ");
                            let robotNameString = queueRobots.join(", ");
                            let queueRobotNames = queueNameString + "|" + robotNameString
                            var chart8 = {
                                uuid : userId,
                                chartName : "chart8",
                                robots : queueRobotNames,
                                date1: qttStartTime,
                                date2: qttEndTime
                            }
                            let queueStatusStartTime = $("#queueStatusStartTime").val()
                            let queueStatusEndTime = $("#queueStatusEndTime").val()
                            let queueStatusNames = $("#queueStatusNames").val()
                            let queueStatusNamesString = queueStatusNames.join(", ")
                            var chart9 = {
                                uuid : userId,
                                chartName : "chart9",
                                robots : queueStatusNamesString,
                                date1: queueStatusStartTime,
                                date2: queueStatusEndTime
                            }
                            chartData.push(chart1, chart2, chart3, chart4, chart5, chart6, chart8, chart9)
                            savedChartFilters = {historyList: chartData}

                            $.ajax({
                                url: "/rpad-history",
                                type: 'POST',
                                data: savedChartFilters,
                                dataType: 'json',
                                success: function (res) {
                                    console.log(`send process is successful`)
                                },
                                error: function (xhr, status, error) {
                                    console.error(`error message : ${error}\nerror status : ${status}\nerror xhr : ${xhr}`)
                                }
                            })
                        });

                        $(".datepicker2").toArray().forEach(function (inp) {
                            var $this = $(inp),
                                options2 = {
                                    format: "dd/mm/yyyy",
                                    orientation: 'bottom left',
                                    language: locale,
                                };
                            $this.datepicker(options2);
                        });
                    });



                    $(window).on("load",function () {
                        $('#exampleModal').on('hide.bs.modal', function () {
                            if (document.activeElement && typeof document.activeElement.blur === 'function') {
                                document.activeElement.blur();
                            }
                        });

                        const arrangement = JSON.parse('!{JSON.stringify(arrangement)}')
                        const rpadChartsStatusList = arrangement && arrangement.rpadChartsStatusList ? arrangement.rpadChartsStatusList : [];
                        let currentOrder = []
                        for (let i=0;i<8;i++){
                            currentOrder.push(rpadChartsStatusList[i] ? rpadChartsStatusList[i].location : i)
                        }
                        $("#sortable .chart-div").sort(function(a, b) {
                            return $(a).data("position") - $(b).data("position");
                        }).appendTo("#bout");
                        $("#sortable .chart-div").sort(function(a, b) {
                            // İki div'in data-order değerlerini al
                            let aOrder = $(a).data("order");
                            let bOrder = $(b).data("order");

                            return currentOrder.indexOf(aOrder) - currentOrder.indexOf(bOrder);
                        }).appendTo("#sortable");


                        for (let i = 0; i < rpadChartsStatusList.length; i++) {
                            if (!rpadChartsStatusList[i].chartStatus) {
                                const chartDivId = `chart-${i + 1}-div`;
                                $('#' + chartDivId).addClass('d-none');
                            }
                        }

                        // Re-initialise feather icons for sidebar
                        feather.replace();

                        if (uploadMode) {
                            $('#exampleModal').modal('show');
                        }

                    })