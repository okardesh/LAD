extends ../layout
block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        style.
            :root {
                --rpad-bg: #f3f5f8;
                --rpad-card: #ffffff;
                --rpad-border: #e6ebf3;
                --rpad-shadow: 0 10px 24px rgba(16,24,40,.06);
                --rpad-shadow-hover: 0 18px 32px rgba(16,24,40,.12);
                --rpad-text: #1f2937;
                --rpad-muted: #667085;
                --rpad-primary: #2f5ecc;
            }

            @keyframes rpadFadeUp {
                from { opacity: 0; transform: translateY(6px); }
                to { opacity: 1; transform: translateY(0); }
            }

            /* ── Layout ── */
            header.topbar { display: none !important; }
            .page-wrapper {
                margin-left: 230px !important;
                padding-top: 10px !important;
                transition: margin-left 0.3s ease;
                background: radial-gradient(1200px 400px at 0% 0%, #f7f9ff 0%, var(--rpad-bg) 45%) !important;
                min-height: 100vh;
            }
            .page-wrapper.rpad-sidebar-collapsed { margin-left: 72px !important; }
            @media (max-width: 768px) {
                .rpad-sidebar { left: -260px !important; }
                .rpad-sidebar.mobile-open { left: 0 !important; }
                .page-wrapper { margin-left: 0 !important; }
            }

            /* ── Sidebar shell ── */
            .rpad-sidebar {
                position: fixed !important;
                left: 0 !important;
                top: 0 !important;
                width: 230px !important;
                height: 100vh !important;
                background: #ffffff !important;
                box-shadow: 1px 0 2px rgba(16,24,40,.06) !important;
                display: flex !important;
                flex-direction: column !important;
                z-index: 1050 !important;
                transition: width .25s ease !important;
                overflow: hidden !important;
            }
            .rpad-sidebar.rpad-sidebar--collapsed { width: 72px !important; }

            /* ── Sidebar header ── */
            .rpad-sidebar__header {
                display: flex !important;
                align-items: center !important;
                justify-content: space-between !important;
                padding: 10px 12px !important;
                border-bottom: 1px solid #edf0f4 !important;
                flex-shrink: 0 !important;
                min-height: 56px !important;
            }
            .rpad-sidebar--collapsed .rpad-sidebar__header { justify-content: center !important; }
            .rpad-sidebar__logo img { height: 28px !important; transition: opacity .2s; }
            .rpad-sidebar--collapsed .rpad-sidebar__logo img { opacity: 0; width: 0; overflow: hidden; }
            .rpad-sidebar__toggle {
                background: none !important;
                border: none !important;
                cursor: pointer !important;
                padding: 6px !important;
                color: #8c8c8c !important;
                border-radius: 6px !important;
                display: flex !important;
                align-items: center !important;
                justify-content: center !important;
                flex-shrink: 0 !important;
            }
            .rpad-sidebar__toggle:hover { background: #f5f5f5 !important; color: #262626 !important; }
            .rpad-sidebar__toggle .svg-icon { width: 20px !important; height: 20px !important; }

            /* ── Sidebar nav ── */
            .rpad-sidebar__nav { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 10px 0; }
            .rpad-sidebar__section { margin-bottom: 4px; }
            .rpad-sidebar__section-title {
                padding: 10px 18px 6px;
                font-size: 12px;
                font-weight: 700;
                color: #9aa3b2;
                letter-spacing: 0;
                text-transform: none;
                white-space: nowrap;
                overflow: hidden;
                transition: opacity .2s;
            }
            .rpad-sidebar--collapsed .rpad-sidebar__section-title { opacity: 0; }
            .rpad-sidebar__menu { list-style: none !important; padding: 0 !important; margin: 0 !important; }
            .rpad-sidebar__item { margin: 2px 8px !important; }
            .rpad-sidebar__link {
                display: flex !important;
                align-items: center !important;
                padding: 10px 12px !important;
                border-radius: 8px !important;
                color: #4b5563 !important;
                text-decoration: none !important;
                font-size: 13px !important;
                font-weight: 500 !important;
                transition: background .15s, color .15s;
                gap: 10px !important;
                white-space: nowrap;
                overflow: hidden;
            }
            .rpad-sidebar__link:hover { background: #f2f5fb !important; color: #1d4ed8 !important; }
            .rpad-sidebar__link.active { background: #e9efff !important; color: #2957c8 !important; font-weight: 600 !important; }
            .rpad-sidebar__link .svg-icon { width: 17px !important; height: 17px !important; flex-shrink: 0 !important; }
            .rpad-sidebar--collapsed .rpad-sidebar__link span { opacity: 0; width: 0; overflow: hidden; }

            /* ── Sidebar profile ── */
            .rpad-sidebar__profile {
                display: flex !important;
                align-items: center !important;
                gap: 10px !important;
                padding: 14px 16px !important;
                border-top: 1px solid #f0f0f0 !important;
                flex-shrink: 0 !important;
                overflow: hidden !important;
            }
            .rpad-sidebar__avatar { width: 34px !important; height: 34px !important; border-radius: 50% !important; object-fit: cover !important; flex-shrink: 0 !important; }
            .rpad-sidebar__avatar-placeholder {
                width: 34px !important; height: 34px !important; border-radius: 50% !important;
                background: #1890ff !important; color: #fff !important;
                display: flex !important; align-items: center !important; justify-content: center !important;
                font-size: 13px !important; font-weight: 600 !important; flex-shrink: 0 !important;
            }
            .rpad-sidebar__user-info { flex: 1; min-width: 0; transition: opacity .2s; }
            .rpad-sidebar--collapsed .rpad-sidebar__user-info { opacity: 0; width: 0; overflow: hidden; }
            .rpad-sidebar__user-name { display: block; font-size: 12.5px; font-weight: 600; color: #262626; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
            .rpad-sidebar__user-role { display: block; font-size: 11px; color: #8c8c8c; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
            .rpad-sidebar__logout { flex-shrink: 0; color: #bfbfbf; display: flex !important; align-items: center; justify-content: center; padding: 5px; border-radius: 6px; transition: color .2s, background .2s; }
            .rpad-sidebar__logout:hover { color: #ff4d4f !important; background: #fff1f0 !important; text-decoration: none !important; }
            .rpad-sidebar__logout .svg-icon { width: 17px !important; height: 17px !important; }

            /* ── Stat cards ── */
            .dashboard-shell { max-width: 1240px; margin: 0 auto; }
            .dashboard-topbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                margin-bottom: 14px;
            }
            .dashboard-topbar__left {
                display: flex;
                align-items: center;
                gap: 10px;
                flex-wrap: wrap;
            }
            .dashboard-title {
                font-size: 32px;
                font-weight: 700;
                color: var(--rpad-text);
                margin: 0;
                line-height: 1;
                letter-spacing: -0.02em;
                background: linear-gradient(180deg, #22314b 0%, #1f4cb8 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }
            .dashboard-chip {
                font-size: 12px;
                color: #64748b;
                border: 1px solid #d7e1f0;
                border-radius: 999px;
                background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
                padding: 4px 10px;
            }
            .dashboard-topbar__right { display: flex; align-items: center; gap: 8px; }
            .view-mode-switch {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                height: 38px;
                padding: 0 10px;
                border: 1px solid #d1dbec;
                border-radius: 12px;
                background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
                color: #475467;
                font-size: 12px;
                font-weight: 700;
            }
            .view-mode-switch__label { opacity: .7; }
            .view-mode-switch__label.active { opacity: 1; color: #1f2937; }
            .view-mode-switch input[type='checkbox'] {
                appearance: none;
                width: 40px;
                height: 22px;
                border-radius: 999px;
                background: #cdd6e5;
                position: relative;
                outline: none;
                cursor: pointer;
                transition: background .2s ease;
            }
            .view-mode-switch input[type='checkbox']:before {
                content: '';
                position: absolute;
                top: 2px;
                left: 2px;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: #fff;
                box-shadow: 0 1px 3px rgba(0,0,0,.2);
                transition: left .2s ease;
            }
            .view-mode-switch input[type='checkbox']:checked {
                background: #2f5ecc;
            }
            .view-mode-switch input[type='checkbox']:checked:before {
                left: 20px;
            }
            .dash-btn {
                border: 1px solid #d1dbec;
                background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
                border-radius: 12px;
                height: 38px;
                padding: 0 14px;
                font-size: 14px;
                color: #374151;
                font-weight: 500;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                box-shadow: 0 2px 6px rgba(15,23,42,.05);
            }
            .dash-btn--primary {
                border-color: #2754c6;
                color: #ffffff;
                background: linear-gradient(180deg,#3b6ff0 0%,#2754c6 100%);
            }
            .rpad-stats-row { display: flex !important; gap: 10px !important; flex-wrap: wrap !important; margin-bottom: 14px !important; }
            .rpad-stat-card {
                flex: 1 !important;
                min-width: 185px !important;
                background: linear-gradient(180deg,#ffffff 0%,#fbfdff 100%) !important;
                border-radius: 12px !important;
                padding: 14px 14px !important;
                border: 1px solid #dfe6f3;
                box-shadow: 0 8px 18px rgba(16,24,40,.06) !important;
                display: flex !important;
                align-items: center !important;
                justify-content: space-between !important;
                gap: 10px !important;
            }
            .rpad-stat-card__info { flex: 1; min-width: 0; }
            .rpad-stat-card__label { font-size: 13px; color: #8b93a1; font-weight: 500; margin-bottom: 6px; text-transform: none; letter-spacing: 0; }
            .rpad-stat-card__value { font-size: 34px !important; font-weight: 700 !important; color: #1f2937 !important; line-height: 1; }
            .rpad-stat-card__icon { width: 44px !important; height: 44px !important; border-radius: 6px !important; display: flex !important; align-items: center !important; justify-content: center !important; flex-shrink: 0 !important; }
            .rpad-stat-card__icon .svg-icon { width: 18px !important; height: 18px !important; }
            .rpad-stat-card__icon--blue,
            .rpad-stat-card__icon--purple,
            .rpad-stat-card__icon--orange,
            .rpad-stat-card__icon--green { background: #eaf1ff !important; }
            .rpad-stat-card__icon .svg-icon { color: #2f5ecc !important; stroke: #2f5ecc !important; }

            .dashboard-toolbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 10px;
                margin-bottom: 12px;
            }
            .dashboard-tabs {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 8px;
                width: 100%;
                max-width: 640px;
            }
            .dashboard-tab {
                height: 38px;
                border: 1px solid #e3e7ef;
                border-radius: 10px;
                background: #f6f7fa;
                color: #5a6575;
                font-size: 14px;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                letter-spacing: .01em;
            }
            .dashboard-tab.active {
                background: #fff;
                border-color: #d4dbeb;
                color: #303a4a;
                box-shadow: 0 1px 2px rgba(16,24,40,.06);
            }
            .dashboard-actions {
                display: flex;
                border: 1px solid #d7dfef;
                border-radius: 12px;
                background: linear-gradient(180deg,#f8faff 0%,#f2f6fd 100%);
                padding: 2px;
                gap: 4px;
            }
            .dash-chip-btn {
                height: 38px;
                border-radius: 10px;
                border: 1px solid #d7ddea;
                padding: 0 14px;
                font-size: 14px;
                font-weight: 600;
                color: #3b4453;
                background: #fff;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                transition: all .18s ease;
            }
            .dash-chip-btn:hover {
                border-color: #c5cfdf;
                background: #f8faff;
            }
            .dash-chip-btn.primary {
                background: #2f5ecc;
                border-color: #2f5ecc;
                color: #fff;
            }
            .dash-chip-btn.primary:hover {
                background: #244ea9;
                border-color: #244ea9;
            }

            .dashboard-config-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(16,24,40,.45);
                z-index: 1998;
                display: none;
            }
            .dashboard-config-backdrop.open { display: block; }
            .dashboard-config-panel {
                position: fixed;
                top: 0;
                right: -520px;
                width: 500px;
                max-width: 96vw;
                height: 100vh;
                background: #fff;
                z-index: 1999;
                border-left: 1px solid #e5e7eb;
                box-shadow: -12px 0 40px rgba(2, 6, 23, .18);
                transition: right .25s ease;
                display: flex;
                flex-direction: column;
            }
            .dashboard-config-panel.open { right: 0; }
            .cfg-head {
                height: 58px;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 0 16px;
                border-bottom: 1px solid #edf1f6;
                font-size: 30px;
                font-weight: 700;
                color: #1f2937;
            }
            .cfg-close {
                border: none;
                background: transparent;
                color: #9ca3af;
                font-size: 26px;
                line-height: 1;
                padding: 0;
            }
            .cfg-body {
                flex: 1;
                overflow: auto;
                padding: 16px;
                background: #f9fafb;
            }
            .cfg-note {
                border: 1px solid #f2d06f;
                background: #fff9e8;
                border-radius: 8px;
                color: #7c5f10;
                padding: 10px 12px;
                font-size: 20px;
                margin-bottom: 12px;
            }
            .cfg-section {
                border: 1px solid #e6eaf1;
                border-radius: 8px;
                background: #fff;
                padding: 12px;
                margin-bottom: 12px;
            }
            .cfg-section-head {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 10px;
            }
            .cfg-section-title {
                font-size: 30px;
                font-weight: 700;
                color: #2f3a4b;
            }
            .cfg-section-divider {
                border-top: 1px solid #eef1f5;
                margin: 8px 0 10px;
            }
            .cfg-grid-3 {
                display: grid;
                grid-template-columns: repeat(3, minmax(0,1fr));
                gap: 8px;
            }
            .cfg-grid-1 {
                display: grid;
                grid-template-columns: 1fr;
                gap: 8px;
                margin-top: 8px;
            }
            .cfg-item {
                border: 1px solid #e7ebf2;
                border-radius: 8px;
                background: #fff;
                min-height: 72px;
                padding: 8px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                text-align: center;
                gap: 8px;
            }
            .cfg-item__title {
                font-size: 16px;
                color: #374151;
                font-weight: 600;
                line-height: 1.25;
            }
            .cfg-item__actions {
                display: inline-flex;
                border: 1px solid #e5e7eb;
                border-radius: 6px;
                overflow: hidden;
            }
            .cfg-act-btn {
                width: 34px;
                height: 24px;
                border: none;
                background: #f5f6f8;
                color: #6b7280;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 0;
            }
            .cfg-act-btn.active {
                background: #e8efff;
                color: #2f5ecc;
            }
            .cfg-act-btn + .cfg-act-btn { border-left: 1px solid #e5e7eb; }
            .cfg-switch-wrap {
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }
            .cfg-switch-label {
                font-size: 16px;
                color: #6b7280;
                border: 1px solid #e5e7eb;
                border-radius: 6px;
                padding: 2px 8px;
            }
            .cfg-switch {
                appearance: none;
                width: 40px;
                height: 22px;
                border-radius: 999px;
                background: #cfd5de;
                position: relative;
                outline: none;
                cursor: pointer;
            }
            .cfg-switch:before {
                content: '';
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: #fff;
                position: absolute;
                top: 2px;
                left: 2px;
                transition: all .2s ease;
            }
            .cfg-switch:checked { background: #2f5ecc; }
            .cfg-switch:checked:before { left: 20px; }
            .cfg-footer {
                border-top: 1px solid #edf1f6;
                padding: 12px 16px;
                background: #fff;
                display: flex;
                justify-content: flex-end;
            }
            .cfg-save-btn {
                border: none;
                background: #2f5ecc;
                color: #fff;
                border-radius: 8px;
                height: 36px;
                padding: 0 16px;
                font-size: 18px;
                font-weight: 600;
            }

            .chart-div { margin-bottom: 14px; }
            .chart-div .dashboard-big--div,
            .chart-div .dashboard-big--div--second1 {
                background: var(--rpad-card) !important;
                border: 1px solid var(--rpad-border) !important;
                border-radius: 14px !important;
                box-shadow: var(--rpad-shadow) !important;
                overflow: hidden;
                transition: transform .2s ease, box-shadow .2s ease;
                position: relative;
                animation: rpadFadeUp .32s ease both;
                transform-style: preserve-3d;
                perspective: 1000px;
            }
            .chart-div .dashboard-big--div:before,
            .chart-div .dashboard-big--div--second1:before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 35%, #22d3ee 100%);
                opacity: .9;
            }
            .chart-div .dashboard-big--div:hover,
            .chart-div .dashboard-big--div--second1:hover {
                transform: translateY(-4px) rotateX(1.2deg) rotateY(-1deg);
                box-shadow: var(--rpad-shadow-hover) !important;
            }
            .chart-div .dashboard-big--div:after,
            .chart-div .dashboard-big--div--second1:after {
                content: '';
                position: absolute;
                left: 14px;
                right: 14px;
                bottom: -14px;
                height: 20px;
                border-radius: 50%;
                background: radial-gradient(ellipse at center, rgba(15,23,42,.22) 0%, rgba(15,23,42,0) 72%);
                filter: blur(3px);
                z-index: -1;
                pointer-events: none;
                opacity: .75;
                transition: opacity .2s ease, transform .2s ease;
            }
            .chart-div .dashboard-big--div:hover:after,
            .chart-div .dashboard-big--div--second1:hover:after {
                opacity: 1;
                transform: translateY(2px) scale(1.03);
            }
            .second-area {
                background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%) !important;
                border-bottom: 1px solid #eef2f7 !important;
                padding: 14px 16px !important;
                margin-bottom: 0 !important;
                position: relative;
                box-shadow: inset 0 1px 0 rgba(255,255,255,.9), inset 0 -1px 0 rgba(15,23,42,.03);
            }
            .second-area:after {
                content: '';
                position: absolute;
                left: 16px;
                bottom: 8px;
                width: 52px;
                height: 3px;
                border-radius: 999px;
                background: linear-gradient(90deg, #2f5ecc 0%, #6aa6ff 100%);
                opacity: .45;
            }
            .second-area li {
                font-size: 16px !important;
                font-weight: 700 !important;
                color: #1f2937 !important;
                line-height: 1.2;
                letter-spacing: .1px;
            }

            /* Chart surface polish */
            .chart-div [id^='rpad-chart'] {
                min-height: 280px;
                border-radius: 10px;
                background: radial-gradient(circle at 50% 18%, rgba(99,149,249,.08) 0%, rgba(99,149,249,0) 48%);
            }
            .chart-div canvas {
                filter: saturate(1.06) contrast(1.02);
            }
            .chart-div .g2-tooltip,
            .chart-div .g2-tooltip-list {
                transform: translateZ(18px);
            }

            .pie-3d-stack {
                position: relative;
                min-height: 280px;
                overflow: visible;
            }
            .pie-3d-stack__depth,
            .pie-3d-stack__top {
                position: absolute;
                inset: 0;
            }
            .pie-3d-stack__depth {
                pointer-events: none;
                display: none;
            }
            .page-wrapper.view-3d .pie-3d-stack__top {
                transform: translateY(0);
            }
            .page-wrapper.view-2d .pie-3d-stack__depth {
                display: none;
            }
            .page-wrapper.view-3d .pie-3d-stack__top,
            .page-wrapper.view-3d .pie-3d-stack__depth {
                z-index: 1;
            }
            .page-wrapper.view-3d .pie-3d-stack canvas {
                filter: saturate(1.08) contrast(1.03);
            }

            .state-battery {
                width: 100%;
                max-width: 470px;
                margin: 20px auto 0;
                padding: 18px 8px 6px;
            }
            .state-battery--2d {
                padding-top: 10px;
            }
            .state-battery__shell {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 24px;
            }
            .state-battery--2d .state-battery__shell {
                gap: 8px;
                margin-bottom: 18px;
            }
            .state-battery__body {
                flex: 1;
                height: 92px;
                border-radius: 22px;
                background: #eef2f7;
                padding: 10px;
                box-shadow: inset 0 2px 8px rgba(15,23,42,.08);
                position: relative;
                overflow: hidden;
            }
            .state-battery--2d .state-battery__body {
                background: #eef4fb;
                box-shadow: inset 0 1px 3px rgba(15,23,42,.06);
                border: 1px solid #dbe4f1;
            }
            .state-battery__segments {
                width: 100%;
                height: 100%;
                border-radius: 16px;
                overflow: hidden;
                display: flex;
                background: #d9e2ee;
            }
            .state-battery--2d .state-battery__segments {
                background: #e2eaf4;
            }
            .state-battery__segment {
                height: 100%;
                position: relative;
                min-width: 0;
            }
            .state-battery__segment--success { background: linear-gradient(180deg, #19a35b 0%, #108245 100%); }
            .state-battery__segment--faulted { background: linear-gradient(180deg, #b23443 0%, #962a38 100%); }
