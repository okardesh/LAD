        script.
            const {Pie} = G2Plot;
            const checkRoles = JSON.parse('!{JSON.stringify(checkRoles)}')
            const filters = JSON.parse('!{JSON.stringify(filters)}')
            const uploadMode = !{JSON.stringify(uploadMode || false)}
            const lastDataDateInformation = JSON.parse('!{JSON.stringify(lastDataDateInformation)}')
            const lastQueueDateInformation = JSON.parse('!{JSON.stringify(lastQueueDateInformation)}')
            const lastDataDate = lastDataDateInformation[0]?.lastDate
            const lastJobsDate = lastDataDateInformation[0]?.lastJobsDate
            var lastQueueDate = lastQueueDateInformation[0]?.lastQueueDate || undefined
            if (lastQueueDate === undefined){
                lastQueueDate = lastJobsDate
            }
            var currentDate = new Date();
            var currentDayYear = currentDate.getFullYear();
            var currentDayMonth = currentDate.getMonth()+1;
            var currentDay = currentDate.getDate();

            var formatedCurrentDate = ('0' + currentDay).slice(-2) + '/' + ('0' + currentDayMonth).slice(-2) + '/' + currentDayYear;

            function parseDashboardDate(dateStr) {
                if (!dateStr || typeof dateStr !== 'string') return null;
                const parts = dateStr.split('/');
                if (parts.length !== 3) return null;
                const day = parseInt(parts[0], 10);
                const month = parseInt(parts[1], 10);
                const year = parseInt(parts[2], 10);
                if (!day || !month || !year) return null;
                return new Date(year, month - 1, day);
            }

            function formatDashboardDate(date) {
                if (!date) return formatedCurrentDate;
                return ('0' + date.getDate()).slice(-2) + '/' + ('0' + (date.getMonth() + 1)).slice(-2) + '/' + date.getFullYear();
            }

            function getLastWeekRange(anchorDateStr) {
                const anchorDate = parseDashboardDate(anchorDateStr) || parseDashboardDate(formatedCurrentDate) || new Date();
                const end = new Date(anchorDate.getFullYear(), anchorDate.getMonth(), anchorDate.getDate());
                const start = new Date(end);
                start.setDate(end.getDate() - 6);
                return {
                    start: formatDashboardDate(start),
                    end: formatDashboardDate(end)
                };
            }

            function shiftDashboardDate(anchorDateStr, days) {
                const baseDate = parseDashboardDate(anchorDateStr) || parseDashboardDate(formatedCurrentDate) || new Date();
                const shifted = new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate());
                shifted.setDate(shifted.getDate() + days);
                return formatDashboardDate(shifted);
            }

            const dashboardDefaultDate = shiftDashboardDate(lastJobsDate || lastDataDate || formatedCurrentDate, -1);
            const queueDefaultDate = shiftDashboardDate(lastQueueDate || lastJobsDate || formatedCurrentDate, -1);
            const dashboardDataWeekRange = { start: dashboardDefaultDate, end: dashboardDefaultDate };
            const queueDataWeekRange = { start: queueDefaultDate, end: queueDefaultDate };
            const dashboardWeeklyRange = getLastWeekRange(dashboardDefaultDate);
            const saved3DMode = localStorage.getItem('rpadViewMode3d');
            const is3DView = saved3DMode === null ? true : saved3DMode === '1';
            window.__rpad3dEnabled = is3DView;

            function ensureSelectHasValue(selectName) {
                const $select = $('select[name="' + selectName + '"]');
                let selected = $select.val();
                if (selected && selected.length > 0) return selected;
                const allValues = $select.find('option').map(function () { return this.value; }).get().filter(Boolean);
                if (allValues.length > 0) {
                    $select.val(allValues);
                    $select.trigger('change.select2');
                    return allValues;
                }
                return [];
            }

            $(window).on('load', function () {
                const $wrapper = $('.page-wrapper');
                $wrapper.toggleClass('view-3d', is3DView);
                $wrapper.toggleClass('view-2d', !is3DView);

                const $toggle = $('#viewMode3DToggle');
                if ($toggle.length) {
                    $toggle.prop('checked', is3DView);
                    $('#viewMode2DLabel').toggleClass('active', !is3DView);
                    $('#viewMode3DLabel').toggleClass('active', is3DView);
                    $toggle.off('change.viewMode').on('change.viewMode', function () {
                        const enabled = $(this).is(':checked');
                        localStorage.setItem('rpadViewMode3d', enabled ? '1' : '0');
                        window.location.reload();
                    });
                }
            });


