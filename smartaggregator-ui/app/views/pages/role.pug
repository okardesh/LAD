extends ../layout

block content
  #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
    include ../partials/header
      
    .page-wrapper
      form(id='role', method='POST')
        input(type='hidden', name='_csrf', value=_csrf)
        input(type='hidden', name='uuid', id='uuid' value=role.uuid)
        input(type='hidden', name='approvalStatus', id='approvalStatus' value=role.approvalStatus)
        .page-breadcrumb
          .row
            .col-md-5.col-lg-4.align-self-center
              h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Role')}
              .d-flex.align-items-center
                nav(aria-label='breadcrumb')
                  ol.breadcrumb.m-0.p-0
                    li.breadcrumb-item
                      a.text-muted.active-link(href='/') #{__('Home')}
                    li.breadcrumb-item
                      a.text-muted.active-link(href='/roles') #{__('Roles')}
                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Role')}
            .col-md-7.col-lg-8
              .row.justify-content-end
                if role.uuid
                  .col-sm-4.col-lg-3
                    button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='submit', name='action', value='new')
                        i.fas.fa-plus
                        |  #{__('New')}
                  if(role.approvalStatus === 'N' || role.approvalStatus === 'R')
                      .col-sm-4.col-lg-3
                          button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-warning.font-12(type='submit', name='action', value='update')
                              i.far.fa-edit
                              |  #{__('Update')}
                  if((user.rolePermissionAll.includes('/v1/roles/{uuid}/sendForApproval_POST') || user.rolePermissionAll.includes('/v1/roles/{uuid}/approve_POST')) && (uuid !== 'new'))
                      .col-sm-4.col-lg-3
                          button.form-control.myBtn.btn-rounded.btn.waves-effect.waves-light.btn-success.font-10(title='Popup')&attributes({'data-value': role.uuid} , {'data-approval': role.approvalStatus} , {'data-auth': user} , {'data-message': role.approvalMessage} , {'data-controller': 'roles'})
                              i.fas.fa-check-square
                              |
                              | #{__('Approval Processes')}
                else
                  .col-sm-4.col-lg-3
                    button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-success.font-12(type='submit', name='action', value='save')
                        i.fas.fa-save
                        |  #{__('Save')}
          .row.mt-4.ml-0
            div#info.text-primary&attributes({'data-html': info})
        .container-fluid.p-3
            .card
              .card-body
                .row
                  .col-md-4
                    .form-group
                      label.col-form-label(for='code') #{__('Code')}
                      input.form-control(type='text', name='code', id='code',autocomplete = "off" , placeholder=__('Code'), maxlength='64',value=role.code)
                  .col-md-4
                    .form-group
                      label.col-form-label(for='description') #{__('Description')}
                      input.form-control(type='text', name='description', id='description',autocomplete = "off" , placeholder=__('Description'), value=role.description)
                  .col-md-4
                    .form-group
                        label.col-form-label(for='status') #{__('Status')}
                        br
                        input(type='checkbox'  name='status' id='status' checked=!role.status || role.status === 1 data-toggle='toggle' data-on=__('Active') data-off=__('Passive') data-style="ios" data-size="small")
                .row
                  .col-md-12
                    .form-group
                      label.col-form-label(for='subsidiaryView') &nbsp; #{__('SubsidiaryView')}
                      br
                      input(type='checkbox'  name='subsidiaryView' id='subsidiaryView' checked=role.subsidiaryView == 1 ? true : false, data-toggle='toggle' data-on=__('Active') data-off=__('Passive') data-style="ios" data-size="small")
                .row
                  .col-md-12
                    .form-group
                      .d-flex.justify-content-between
                        label.col-form-label(for='operations') #{__('Operations')}
                        button.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12.ml-auto.selectAll(type='button')
                          i.far.fa-check-square
                          |  #{__('Select All')}
                      select.js-multiple-select.js-states.form-control.customSelectionClass(multiple='multiple', name='operations', id='operations')
                        if operations
                          each operation in operations
                            option(value=operation.uuid, selected=role.operations.includes(operation.uuid))= __('description.uri.' + operation.method + operation.path)
      if role.history
        .container-fluid.p-3
            .card
              .card-header.bg-transparent
                .row.align-items-baseline
                  .com-sm-5.col-md-5.col-lg-4.mb-0
                    h5
                      i.fas.fa-info-circle(style="margin-right:5px;margin-left:-10px;color:royalblue")
                        | #{__('Data History')}

              .card-body
                  .table-responsive.dragscroll
                    table#roleTable.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                      thead
                        tr
                          th.notexport
                          th #{__('Code')}
                          th #{__('Description')}
                          th #{__('Last Updated By')}
                          th #{__('Last Updated Time')}
                          th #{__('Approval Status')}
                        tbody
                          each item in role.history
                            tr
                              td
                              td=item.code
                              td=item.description
                              td=item.lastUpdaterName
                              td=item.lastUpdatedTime
                              td.text-center(style='font-weight:bold ; color: ' + getApprovalStatusColor(item.approvalStatus))=status(item.approvalStatus)
                    script.
                      $('#deleteRecord').on('click', function (e) {
                        e.preventDefault();
                        removeConfirm("role");
                      });
