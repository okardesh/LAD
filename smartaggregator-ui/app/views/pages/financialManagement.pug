extends ../layout

block content
    #main-wrapper.rpad-layout(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/rpad-sidebar

        style.
            .upload-figma-shell { display: flex; min-height: calc(100vh - 64px); background: #f5f6f8; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
            .upload-figma-main { position: relative; flex: 1; padding: 24px 20px; overflow: hidden; }
            .upload-figma-main::after {
                content: '';
                position: absolute;
                inset: 0;
                background: rgba(0,0,0,.28);
                pointer-events: none;
            }
            .upload-figma-title { font-size: 16px; font-weight: 600; color: #262626; margin-bottom: 14px; letter-spacing: 0.01em; }
            .upload-figma-card { position: relative; z-index: 1; background: #fff; border-radius: 6px; border: 1px solid #ececec; padding: 0; overflow: hidden; }
            .upload-figma-table { width: 100%; border-collapse: collapse; }
            .upload-figma-table thead th {
                font-size: 13px;
                color: #595959;
                font-weight: 600;
                padding: 11px 14px;
                border-bottom: 1px solid #f0f0f0;
                text-align: left;
                background: #fafafa;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }
            .upload-figma-table tbody td {
                font-size: 13px;
                color: #262626;
                padding: 11px 14px;
                border-bottom: 1px solid #f5f5f5;
            }
            .upload-figma-table tbody tr:last-child td { border-bottom: 0; }

            .data-table-wrap { overflow-x: auto; }
            .upload-figma-table thead th:first-child,
            .upload-figma-table tbody td:first-child { position: sticky; left: 0; background: inherit; z-index: 1; }
            .empty-state { padding: 40px; text-align: center; color: #8c8c8c; font-size: 13px; }
            .row-count { font-size: 12px; color: #8c8c8c; padding: 8px 14px; border-bottom: 1px solid #f0f0f0; background: #fafafa; }

            .upload-drawer {
                width: 400px;
                min-width: 400px;
                background: #fff;
                border-left: 1px solid #e8e8e8;
                display: flex;
                flex-direction: column;
                z-index: 2;
                box-shadow: -2px 0 12px rgba(0,0,0,.06);
            }
            .upload-drawer__head {
                height: 56px;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 0 20px;
                border-bottom: 1px solid #f0f0f0;
            }
            .upload-drawer__close {
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                width: 24px;
                height: 24px;
                border-radius: 4px;
                color: #8c8c8c;
                font-size: 18px;
                line-height: 1;
                transition: background .15s, color .15s;
            }
            .upload-drawer__close:hover { background: #f5f5f5; color: #262626; }
            .upload-drawer__title { margin: 0; font-size: 16px; font-weight: 600; color: #1a1a1a; letter-spacing: 0.01em; }
            .upload-drawer__body { padding: 20px; flex: 1; }

            .upload-label { display: block; font-size: 13px; font-weight: 500; color: #333; margin: 0 0 8px; }
            .upload-label .req { color: #ff4d4f; margin-right: 4px; }
            .upload-section { margin-bottom: 20px; }

            .type-tabs {
                display: inline-flex;
                border: 1px solid #d9d9d9;
                border-radius: 6px;
                overflow: hidden;
            }
            .type-tab {
                padding: 7px 20px;
                font-size: 13px;
                font-family: inherit;
                color: #444;
                background: #fff;
                border: none;
                border-right: 1px solid #d9d9d9;
                cursor: pointer;
                transition: background .15s, color .15s;
                line-height: 1.4;
            }
            .type-tab:last-child { border-right: 0; }
            .type-tab:hover:not(.active) { background: #fafafa; }
            .type-tab.active {
                color: #2557c0;
                background: #f0f5ff;
                font-weight: 500;
            }

            .dropzone {
                border: 1px dashed #d9d9d9;
                border-radius: 8px;
                min-height: 120px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                cursor: pointer;
                padding: 20px 16px;
                text-align: center;
                transition: border-color .15s, background .15s;
            }
            .dropzone:hover { border-color: #4c82f7; background: #fafcff; }
            .dropzone svg { width: 36px; height: 36px; color: #7da3e0; margin-bottom: 8px; }
            .dropzone .main { font-size: 13px; color: #595959; line-height: 1.5; }
            .dropzone .sub { font-size: 12px; color: #bfbfbf; margin-top: 3px; }

            .file-picked {
                margin-top: 10px;
                border: 1px solid #e8e8e8;
                border-radius: 6px;
                display: none;
                align-items: center;
                justify-content: space-between;
                padding: 8px 12px;
                gap: 8px;
                background: #fafafa;
            }
            .file-picked.visible { display: flex; }
            .file-picked__name {
                font-size: 13px;
                color: #2557c0;
                text-decoration: underline;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                flex: 1;
            }
            .file-picked__remove {
                border: none;
                background: transparent;
                color: #bfbfbf;
                font-size: 15px;
                line-height: 1;
                cursor: pointer;
                padding: 2px 4px;
                border-radius: 3px;
                transition: color .15s, background .15s;
                flex-shrink: 0;
            }
            .file-picked__remove:hover { color: #ff4d4f; background: #fff2f0; }

            .file-note {
                margin-top: 10px;
                background: #e6f4ff;
                border: 1px solid #91caff;
                border-radius: 6px;
                color: #0958d9;
                font-size: 12px;
                padding: 8px 10px;
                display: none;
                line-height: 1.5;
            }
            .file-note.visible { display: flex; align-items: center; gap: 6px; }
            .file-note::before { content: 'ℹ'; font-size: 13px; flex-shrink: 0; }

            .save-wrap { display: flex; justify-content: flex-end; margin-top: 20px; padding-top: 16px; border-top: 1px solid #f0f0f0; }
            .btn-save {
                min-width: 88px;
                height: 34px;
                border-radius: 6px;
                border: 0;
                color: #fff;
                background: #2557c0;
                font-size: 13px;
                font-family: inherit;
                font-weight: 500;
                cursor: pointer;
                padding: 0 18px;
                transition: background .15s;
            }
            .btn-save:hover:not(:disabled) { background: #1a45a8; }
            .btn-save:disabled {
                background: #f5f5f5;
                color: #bfbfbf;
                cursor: not-allowed;
            }

            #uploadFileInput { display: none; }

        .page-wrapper
            .upload-figma-shell
                .upload-figma-main
                    h2.upload-figma-title Süreç Verileri
                    .upload-figma-card
                        if jobs && jobs.length
                            p.row-count= jobs.length + ' kayıt'
                        .data-table-wrap
                            table.upload-figma-table
                                thead
                                    tr
                                        th #
                                        th Veri Tarihi
                                        th Süreç Adı
                                        th Makine
                                        th Başlangıç
                                        th Bitiş
                                        th Süre (dk)
                                        th Durum
                                        th Öncelik
                                        th Kaynak
                                tbody
                                    if jobs && jobs.length
                                        each item, idx in jobs
                                            tr
                                                td= idx + 1
                                                td= item.dataDate || ''
                                                td= item.releaseName || ''
                                                td= item.hostMachineName || ''
                                                td= item.startTime || ''
                                                td= item.endTime || ''
                                                td= item.totalJobTime || ''
                                                td= item.state || ''
                                                td= item.jobPriority || ''
                                                td= item.sourceType || ''
                                    else
                                        tr
                                            td.empty-state(colspan='10') Henüz yüklenmiş veri yok. Sağ taraftan dosya yükleyebilirsiniz.

                form.upload-drawer(method='POST', enctype='multipart/form-data')
                    input(type='hidden', name='_csrf', value=_csrf)
                    input#uploadModel(type='hidden', name='model', value='jobs')
                    input#uploadFileInput(type='file', name='file', accept='.xlsx')

                    .upload-drawer__head
                        a.upload-drawer__close(href='/data-list' aria-label='Kapat') ×
                        h3.upload-drawer__title Veri Yükleme

                    .upload-drawer__body
                        .upload-section
                            label.upload-label
                                span.req *
                                | Veri Türü
                            .type-tabs
                                button.type-tab.active(type='button', data-model='jobs') Süreç
                                button.type-tab(type='button', data-model='queues') Kuyruk

                        .upload-section
                            label.upload-label
                                span.req *
                                | Dosya
                            #dropZone.dropzone
                                svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round')
                                    polyline(points='8 17 12 21 16 17')
                                    line(x1='12' y1='12' x2='12' y2='21')
                                    path(d='M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29')
                                .main Click or drag file to this area to upload
                                .sub Support for a single or bulk upload.

                            #pickedFile.file-picked
                                span#pickedFileName.file-picked__name
                                button#removePickedFile.file-picked__remove(type='button' aria-label='Dosyayı kaldır') ✕

                            #fileNote.file-note

                        .save-wrap
                            button#btnSave.btn-save(type='submit' disabled) Kaydet

    script.
        (function() {
            var modelInput = document.getElementById('uploadModel');
            var fileInput = document.getElementById('uploadFileInput');
            var dropZone = document.getElementById('dropZone');
            var pickedFile = document.getElementById('pickedFile');
            var pickedFileName = document.getElementById('pickedFileName');
            var removePickedFile = document.getElementById('removePickedFile');
            var fileNote = document.getElementById('fileNote');
            var saveBtn = document.getElementById('btnSave');
            var tabs = document.querySelectorAll('.type-tab');

            function setSaveState() {
                saveBtn.disabled = !(fileInput && fileInput.files && fileInput.files.length > 0);
            }

            function setModel(model) {
                modelInput.value = model;
                tabs.forEach(function(btn) {
                    btn.classList.toggle('active', btn.getAttribute('data-model') === model);
                });
            }

            tabs.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    setModel(btn.getAttribute('data-model'));
                });
            });

            function setPickedFileUI(file) {
                if (!file) {
                    pickedFile.classList.remove('visible');
                    fileNote.classList.remove('visible');
                    fileNote.textContent = '';
                    setSaveState();
                    return;
                }

                pickedFile.classList.add('visible');
                pickedFileName.textContent = file.name;
                fileNote.classList.add('visible');
                fileNote.textContent = 'Dosya algılandı: ' + file.name;
                setSaveState();
            }

            dropZone.addEventListener('click', function() {
                fileInput.click();
            });

            fileInput.addEventListener('change', function() {
                setPickedFileUI(fileInput.files[0]);
            });

            removePickedFile.addEventListener('click', function() {
                fileInput.value = '';
                setPickedFileUI(null);
            });

            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
            });

            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                if (!e.dataTransfer || !e.dataTransfer.files || !e.dataTransfer.files.length) return;

                var dropped = e.dataTransfer.files[0];
                var dt = new DataTransfer();
                dt.items.add(dropped);
                fileInput.files = dt.files;
                setPickedFileUI(dropped);
            });

            setModel('jobs');
            setSaveState();
        })();