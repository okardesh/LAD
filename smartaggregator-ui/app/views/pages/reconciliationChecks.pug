extends ../layout

block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/sidebar

        .page-wrapper
            .page-breadcrumb
                .row
                    .col-md-6.col-lg-5.col-xl-4.align-self-center
                        h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Reconciliation Checks')}
                            if(user.rolePermissionAll.includes('/v1/documents/files/{screenCode}_GET'))
                                a.statistic-btn(href="#",onclick=`openPopupDocuments()`)
                                    .far.fa-file
                        .d-flex.align-items-center
                            nav(aria-label='breadcrumb')
                                ol.breadcrumb.m-0.p-0
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/') #{__('Home')}
                                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Reconciliation Checks')}
                    .col-md-6.col-lg-7.col-xl-8
                        form(id='reconciliationChecks', method='POST')
                            input(type='hidden', name='_csrf', value=_csrf)
                            .row.justify-content-end
                                .col-sm-6.col-md-12.col-lg-6
                                    .row.justify-content-end
                                        .col-4
                                            button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='submit', name='action', value='new')
                                                i.fas.fa-plus
                                                |  #{__('New')}
                                        .col-4
                                            button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-10(type='button', name='export', value='xlsx')
                                                i.fas.fa-download
                                                |  #{__('Export')}
                                        .col-4
                                            button.allDataExportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-10(type='button', name='allDataExport', value='xlsx')
                                                i.fas.fa-download
                                                |  #{__('All Data Export')}
                .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
            .container-fluid.p-3
                .row
                    .col-12
                        .card
                            .card-body
                                .table-responsive.dragscroll
                                    table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                        thead
                                            tr
                                                th.notexport
                                                th.status(data-name='status', data-searchable='on', data-sortable='on') #{__('Status')}
                                                th(data-name='subsidiaries', data-searchable='on') #{__('Subsidiary')}
                                                th(data-name='subject', data-searchable='on',data-sortable='on') #{__('Subject')}
                                                th(data-name='query') #{__('Query')}
                                                th(data-name='message', data-searchable='on', data-sortable='on') #{__('Message')}
                                                th(data-name='type', data-searchable='on', data-sortable='on') #{__('Type')}
                                                th(data-name='approvalStatus', data-searchable='on', data-sortable='on', data-toggle='tooltip', data-placement='right', title=__('Approval Status')) #{__('Approval Status')}
                                                if(user.rolePermissionAll.includes('/v1/reconciliation-checks/{uuid}/sendForApproval_POST') || user.rolePermissionAll.includes('/v1/reconciliation-checks/{uuid}/approve_POST'))
                                                    th.notexport(data-toggle='tooltip', data-placement='right', title=__('Approval Processes')) #{__('Approval Processes')}
                                        if reconciliationChecks
                                            tbody
                                                each reconciliationCheck in reconciliationChecks.content
                                                    tr
                                                        td.text-center
                                                            a(href='/reconciliation-check/' + reconciliationCheck.uuid)
                                                                i.fas.fa-eye.fa-2x
                                                        td(style='font-weight:bold; text-align:center; color:  ' + getStatusColor(reconciliationCheck.status))=status(reconciliationCheck.status)
                                                        td
                                                            if subsidiaries
                                                                each subsidiary in subsidiaries
                                                                    if reconciliationCheck.subsidiaries.includes(subsidiary.uuid)
                                                                        div= subsidiary.formalName
                                                        td=reconciliationCheckSubject(reconciliationCheck.subject)
                                                        td
                                                            if reconciliationCheck.query
                                                                a.descript-detail(href='javascript:void(0)')&attributes({
                                                                    'data-content': uCanTrust(reconciliationCheck.query),
                                                                    'data-class': 'xl',
                                                                    'data-contenttype': 'sql'
                                                                })
                                                                    i.fa.fa-paperclip
                                                                    |  #{__('Detail')}
                                                        td
                                                            if reconciliationCheck.message
                                                                each text in reconciliationCheck.message.split(' || ')
                                                                    p= text
                                                        td=reconciliationCheckType(reconciliationCheck.type)
                                                        td.text-center(style='font-weight:bold ; color: ' + getApprovalStatusColor(reconciliationCheck.approvalStatus))=statusNewApprovalChange(reconciliationCheck.approvalStatus)
                                                        if(user.rolePermissionAll.includes('/v1/reconciliation-checks/{uuid}/sendForApproval_POST') || user.rolePermissionAll.includes('/v1/reconciliation-checks/{uuid}/approve_POST'))
                                                            td.text-center&attributes({'data-value': reconciliationCheck.uuid} , {'data-approval': reconciliationCheck.approvalStatus} , {'data-auth': user} , {'data-message': reconciliationCheck.approvalMessage} , {'data-controller': 'reconciliation-checks'})
                                                                button.myBtn.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-10(title='Popup')
                                                                    i.fas.fa-check-square
                                                                    |
                                                                    | #{__('Approval Processes')}
                                +pagination(reconciliationChecks)
    script.
        var subsidiaryList = !{JSON.stringify(subsidiaryList).replace(/<\//g, '<\\/')}
        var typeList = [{key: 'C', value: 'Cutter'},{key: 'I', value: 'Indicator'}]
        function openPopupDocuments() {
            getFilesWindow("RECONCILIATION-CHECKS");
        }