extends ../layout

block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/sidebar

        .page-wrapper
            .page-breadcrumb
                .row
                    .col-md-6.col-lg-5.col-xl-4.align-self-center
                        h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Rules')}
                         if(user.rolePermissionAll.includes('/v1/documents/files/{screenCode}_GET'))
                            a.statistic-btn(href="#",onclick=`openPopupDocuments()`)
                                .far.fa-file
                        .d-flex.align-items-center
                            nav(aria-label='breadcrumb')
                                ol.breadcrumb.m-0.p-0
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/') #{__('Home')}
                                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Rules')}
                    .col-md-6.col-lg-7.col-xl-8
                        form(id='rules', method='POST')
                            input(type='hidden', name='_csrf', value=_csrf)
                            .row.justify-content-end
                                .col-sm-6.col-md-12.col-lg-6
                                    .row.justify-content-end
                                        .col-6
                                            button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='submit', name='action', value='new')
                                                i.fas.fa-plus
                                                |  #{__('New')}
                                        .col-6
                                            button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                                                i.fas.fa-download
                                                |  #{__('Export')}
                .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
            .container-fluid.p-3
                .row
                    .col-12
                        .card
                            .card-body
                                .table-responsive.dragscroll
                                    table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                        thead
                                            tr
                                                th.notexport
                                                th.status(data-name='status', data-searchable='on', data-sortable='on') #{__('Status')}
                                                th(data-name='subsidiaries', data-searchable='on') #{__('Subsidiaries')}
                                                th(data-name='operations', data-searchable='on') #{__('Operation')}
                                                th(data-name='name', data-searchable='on', data-sortable='on') #{__('Name')}
                                                th(data-name='description', data-searchable='on', data-sortable='on') #{__('Description')}
                                                th(data-name='approvalStatus', data-searchable='on', data-sortable='on') #{__('Approval Status')}
                                                if(user.rolePermissionAll.includes('/v1/rules/{uuid}/sendForApproval_POST') || user.rolePermissionAll.includes('/v1/rules/{uuid}/approve_POST'))
                                                    th #{__('Approval Processes')}
                                        if rules
                                            tbody
                                                each rule in rules.content
                                                    tr
                                                        td.text-center
                                                            a(href='/rule/' + rule.uuid)
                                                                i.fas.fa-eye.fa-2x
                                                        td(style='font-weight:bold; text-align:center; color:  ' +  getStatusColor(rule.status))=status(rule.status)
                                                        td
                                                            if subsidiaries
                                                                each subsidiary in subsidiaries
                                                                    if rule.subsidiaries.includes(subsidiary.uuid)
                                                                        div= subsidiary.formalName
                                                        td
                                                            if operations
                                                                each operation in operations
                                                                    if rule.operations.includes(operation.uuid)
                                                                        div= __('description.uri.' + operation.method + operation.path)
                                                        td
                                                            if rule.name
                                                                each text in rule.name.split(' || ')
                                                                    p= text
                                                        td
                                                            if rule.description
                                                                each text in rule.description.split(' || ')
                                                                    p= text
                                                        td.text-center(style='font-weight:bold ; color: ' + getApprovalStatusColor(rule.approvalStatus))=statusNewApprovalChange(rule.approvalStatus)
                                                        if(user.rolePermissionAll.includes('/v1/rules/{uuid}/sendForApproval_POST') || user.rolePermissionAll.includes('/v1/rules/{uuid}/approve_POST'))
                                                            td.text-center&attributes({'data-value': rule.uuid} , {'data-approval': rule.approvalStatus} , {'data-auth': user} , {'data-message': rule.approvalMessage} , {'data-controller': 'rules'})
                                                                button.myBtn.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-10(title='Popup')
                                                                    i.fas.fa-check-square
                                                                    |  #{__('Approval Processes')}
                                +pagination(rules)
    script.
        var subsidiaryList = !{JSON.stringify(subsidiaryList).replace(/<\//g, '<\\/')}
        var operationList = !{JSON.stringify(operationList).replace(/<\//g, '<\\/')}
        function openPopupDocuments() {
            getFilesWindow("RULES");
        };
