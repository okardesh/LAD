extends ../layout

block content
    #main-wrapper(data-theme='light', data-layout='vertical', data-navbarbg='skin6', data-sidebartype='full', data-sidebar-position='fixed', data-header-position='fixed', data-boxed-layout='full')
        include ../partials/header
        include ../partials/sidebar

        .page-wrapper
            .page-breadcrumb
                .row
                    .col-md-6.col-lg-5.col-xl-4.align-self-center
                        h4.page-title.text-truncate.text-dark.font-weight-medium.mb-1 #{__('Deadlines')}
                         if(user.rolePermissionAll.includes('/v1/documents/files/{screenCode}_GET'))
                            a.statistic-btn(href="#",onclick=`openPopupDocuments()`)
                                .far.fa-file

                        .d-flex.align-items-center
                            nav(aria-label='breadcrumb')
                                ol.breadcrumb.m-0.p-0
                                    li.breadcrumb-item
                                        a.text-muted.active-link(href='/') #{__('Home')}
                                    li.breadcrumb-item.text-muted.active(aria-current='page') #{__('Deadlines')}
                    .col-md-6.col-lg-7.col-xl-8
                        form(id='deadlines', method='POST', enctype="multipart/form-data")
                            input(type='hidden', name='_csrf', value=_csrf)
                            .row.justify-content-end
                                .col-3
                                    button.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='submit', name='action', value='new')
                                        i.fas.fa-plus
                                        |  #{__('New')}
                                .col-3
                                    button.exportToExcel.form-control.btn-rounded.btn.waves-effect.waves-light.btn-primary.font-12(type='button', name='export', value='xlsx')
                                        i.fas.fa-download
                                        |  #{__('Export')}
                                .col-6
                                    .file-loading
                                        input#file-input(type='file', name='file', accept='.xlsx, .csv')
                                    #errorBlock.help-block
                .row.mt-4.ml-0
                    div#info.text-primary&attributes({'data-html': info})
            .container-fluid.p-3
                .row
                    .col-12
                        .card
                            .card-body
                                .table-responsive.dragscroll
                                    table.multi-col-order.table.table-striped.table-bordered.display.no-wrap(style='width:100%')
                                        thead
                                            tr
                                                th.notexport
                                                th.status(data-name='status', data-searchable='on') #{__('Status')}
                                                th(data-name='subsidiaries', data-searchable='on') #{__('Subsidiary')}
                                                th(data-name='reportDate',  data-type="date",data-searchable='on') #{__('ReportDate')}
                                                th(data-name='reportType', data-searchable='on') #{__('ReportType')}
                                                th(data-name='dueDate',data-type="date" data-searchable='on') #{__('DueDate')}
                                        if deadlines
                                            tbody
                                                each deadline in deadlines.content
                                                    tr
                                                        td.text-center
                                                            a(href='/deadline/' + deadline.groupId)
                                                                i.fas.fa-eye.fa-2x
                                                        td(style='font-weight:bold; text-align:center; color:  ' +  getStatusColor(deadline.status))=status(deadline.status)
                                                        td
                                                            if subsidiaries
                                                                each subsidiary in subsidiaries
                                                                    if deadline.subsidiaries && deadline.subsidiaries.includes(subsidiary.uuid)
                                                                        div= subsidiary.formalName
                                                        td=deadline.reportDates
                                                        td=__(deadline.reportType)
                                                        td=deadline.dueDate
                                +pagination(deadlines)
    script.
        var subsidiaryList = !{JSON.stringify(subsidiaryList).replace(/<\//g, '<\\/')}
        function openPopupDocuments() {
            getFilesWindow("DEADLINES");
        }